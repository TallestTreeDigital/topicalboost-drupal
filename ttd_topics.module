/**
 * Implements hook_token_info().
 */
function ttd_topics_token_info(): array {
  return [
    'tokens' => [
      'node' => [
        'topicalboost-topics' => [
          'name' => t('TopicalBoost topics display'),
          'description' => t('Rendered TopicalBoost topics display for the node.'),
        ],
      ],
    ],
  ];
}

/**
 * Implements hook_tokens().
 */
function ttd_topics_tokens($type, $tokens, array $data, array $options, BubbleableMetadata $bubbleable_metadata): array {
  $replacements = [];
  if ($type !== 'node' || empty($data['node']) || !$data['node'] instanceof NodeInterface) {
    return $replacements;
  }

  $node = $data['node'];
  foreach ($tokens as $name => $original) {
    if ($name !== 'topicalboost-topics') {
      continue;
    }

    $build = ttd_topics_build_frontend_topics_display($node);
    $replacements[$original] = !empty($build)
      ? (string) \Drupal::service('renderer')->renderPlain($build)
      : '';

    $bubbleable_metadata->addCacheableDependency($node);
    if (!empty($build)) {
      $bubbleable_metadata->addCacheableDependency(BubbleableMetadata::createFromRenderArray($build));
    }
  }

  return $replacements;
}

/**
 * Implements hook_preprocess_HOOK() for node templates.
 */
function ttd_topics_preprocess_node(&$variables) {
  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
  $bundle = $variables['node']->getType();

  if (ttd_topics_is_node_pinned_on_current_topic($variables['node'])) {
    $variables['attributes']['class'][] = 'ttd-pinned-post';
  }

  if (ttd_topics_author_manager_should_hide_author($bundle)) {
    $variables['display_submitted'] = FALSE;
  }

  if (in_array($bundle, $enabled_content_types)) {

    // Check if frontend is enabled or the user has the configured permission.
    $frontend_enabled = $config->get('enable_frontend');
    $user_has_permission = ttd_topics_account_has_required_permission();
    $automatic_mentions_enabled = $config->get('enable_automatic_mentions') ?? TRUE;

    // Still process topics for schema, but control display.
    $variables['show_ttd_topics'] = $frontend_enabled || $user_has_permission;

    // Only add topics for automatic display if automatic mentions is enabled,
    // while still allowing privileged users to preview the frontend output.
    if ($automatic_mentions_enabled || $user_has_permission) {
      // Always process these for schema.
      $variables['topics_list_label'] = $config->get('topics_list_label');
      $maximum_visible_post_topics = $config->get('maximum_visible_post_topics');
      $min_display_count = $config->get('post_topic_minimum_display_count');
      $variables['maximum_visible_post_topics'] = $maximum_visible_post_topics;

      // Use the helper function to get filtered topics.
      $filtered_topics = ttd_topics_get_filtered_topics_for_node($variables['node']);

      // Pass the filtered and sorted topics to the template.
      $variables['filtered_topics'] = $filtered_topics;
    }
  }
}

/**
 * Checks whether a node is pinned on the current TopicalBoost topic page.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The node being rendered.
 *
 * @return bool
 *   TRUE when the node is pinned to the current topic archive.
 */
function ttd_topics_is_node_pinned_on_current_topic(NodeInterface $node): bool {
  $term = \Drupal::routeMatch()->getParameter('taxonomy_term');
  if (!$term instanceof Term || $term->bundle() !== 'ttd_topics' || !$term->hasField('field_pinned_posts')) {
    return FALSE;
  }

  foreach ($term->get('field_pinned_posts') as $ref) {
    if ((int) $ref->target_id === (int) $node->id()) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Gets the configured permission for TopicalBoost topic management.
 *
 * @return string
 *   Permission machine name.
 */
function ttd_topics_get_required_permission() {
  $permission = trim((string) \Drupal::config('ttd_topics.settings')->get('required_permission'));
  return $permission !== '' ? $permission : 'administer topicalboost';
}

/**
 * Checks whether an account has the configured TopicalBoost permission.
 *
 * @param \Drupal\Core\Session\AccountInterface|null $account
 *   Account to check, or NULL for the current user.
 *
 * @return bool
 *   TRUE when the account has the configured permission.
 */
function ttd_topics_account_has_required_permission(?AccountInterface $account = NULL) {
  $account = $account ?: \Drupal::currentUser();
  return $account->hasPermission(ttd_topics_get_required_permission());
}

/**
 * Determines whether default Drupal author UI/output should be hidden.
 */
function ttd_topics_author_manager_should_hide_author(string $bundle): bool {
  $config = \Drupal::config('ttd_topics.settings');
  if (!$config->get('author_manager_enabled')) {
    return FALSE;
  }

  $force_show = array_filter($config->get('author_force_show_content_types') ?: []);
  if (in_array($bundle, $force_show, TRUE)) {
    return FALSE;
  }

  $hidden = array_filter($config->get('author_hide_content_types') ?: []);
  return in_array($bundle, $hidden, TRUE);
}

/**
 * Implements hook_form_FORM_ID_alter() for node_form.
 */
function ttd_topics_form_node_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $node = $form_state->getFormObject()->getEntity();
  if (ttd_topics_author_manager_should_hide_author($node->bundle())) {
    if (isset($form['author'])) {
      $form['author']['#access'] = FALSE;
    }
    if (isset($form['uid'])) {
      $form['uid']['#access'] = FALSE;
    }
  }

  if ($node->hasField('field_ttd_topics')) {
    $config = \Drupal::config('ttd_topics.settings');
    $min_display_count = $config->get('post_topic_minimum_display_count');

    // Hide the original field_ttd_topics field.
    $form['field_ttd_topics']['#access'] = FALSE;

    // Create the TopicalBoost editor in the main content column.
    $form['ttd_topics'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => ['ttd-editor-metabox', 'ttd-editor-metabox-normal'],
      ],
      '#weight' => 50,
    ];
    $form['ttd_topics']['metabox_title'] = [
      '#markup' => '<h2 class="ttd-editor-metabox-title">' . t('TopicalBoost') . '</h2>',
      '#weight' => -100,
    ];

    // Check if the node has been saved at least once.
    $is_saved = !$node->isNew();

    // Check if analysis is in progress.
    $analysis_in_progress = $node->get('field_ttd_analysis_in_progress')->value;
    $meta_gen_enabled = $config->get('enable_meta_generator') ?? FALSE;
    $use_combined_editor = ($meta_gen_enabled && $is_saved && !$analysis_in_progress);
    $topics_field_value = $is_saved ? $node->get('field_ttd_topics')->getValue() : [];
    $has_topics = !empty($topics_field_value);
    $existing_title = $node->hasField('field_ttd_generated_meta_title')
      ? $node->get('field_ttd_generated_meta_title')->value
      : '';
    $existing_description = $node->hasField('field_ttd_generated_meta_desc')
      ? $node->get('field_ttd_generated_meta_desc')->value
      : '';
    $existing_og_title = $node->hasField('field_ttd_generated_og_title')
      ? $node->get('field_ttd_generated_og_title')->value
      : '';
    $existing_og_description = $node->hasField('field_ttd_generated_og_desc')
      ? $node->get('field_ttd_generated_og_desc')->value
      : '';

    // Show status when node is held by block-until-analyzed.
    $block_until_analyzed = $config->get('block_until_analyzed');
    if ($is_saved && $block_until_analyzed && $analysis_in_progress && !$node->isPublished()) {
      $form['ttd_topics']['block_until_analyzed_notice'] = [
        '#markup' => '<div class="messages messages--warning" style="margin-bottom: 12px;"><p>' . t('This content is being held for TopicalBoost analysis and will be published automatically when analysis completes.') . '</p></div>',
        '#weight' => -20,
      ];
    }

    if ($analysis_in_progress) {
      $form['ttd_topics']['analysis_in_progress'] = [
        '#markup' => '
          <div class="ttd-analysis-progress" role="status" aria-live="polite" aria-label="' . t('Analysis in progress') . '">
            <div class="ttd-analysis-progress-content">
              <div class="ttd-analysis-spinner" aria-hidden="true"></div>
              <div class="ttd-analysis-text">
                <h4 class="ttd-analysis-title">' . t('Running TopicalBoost Analysis') . '</h4>
                <p class="ttd-analysis-status">' . t('Analysis in progress') . '<span class="ttd-analysis-dots"><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span></span></p>
              </div>
            </div>
          </div>',
        '#weight' => -10,
        '#attached' => [
          'library' => ['ttd_topics/analysis_progress'],
          'drupalSettings' => [
            'ttdTopics' => [
              'nodeId' => $node->id(),
              'enableStatusPolling' => TRUE,
              'enableDynamicStatus' => FALSE,
            ],
          ],
        ],
      ];
    }
    elseif (!$is_saved) {
      $form['ttd_topics']['not_saved'] = [
        '#markup' => '<p>' . t('Save the content as a draft to enable TopicalBoost analysis.') . '</p>',
        '#weight' => -10,
      ];
    }

    // Add custom CSS to style the explanation.
    $form['#attached']['library'][] = 'ttd_topics/ttd_topics.styles';

    if ($use_combined_editor) {
      $form['#attached']['library'][] = 'ttd_topics/meta_generator';
      $form['#attached']['library'][] = 'ttd_topics/combined_tabs';

      $analysis_icon = '<svg class="ttd-tab-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 9l1.25-2.75L23 5l-2.75-1.25L19 1l-1.25 2.75L15 5l2.75 1.25L19 9zm-7.5.5L9 4 6.5 9.5 1 12l5.5 2.5L9 20l2.5-5.5L17 12l-5.5-2.5zM19 15l-1.25 2.75L15 19l2.75 1.25L19 23l1.25-2.75L23 19l-2.75-1.25L19 15z"/></svg>';
      $seo_icon = '<svg class="ttd-tab-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m20 20-4.5-4.5"></path></svg>';
      $social_icon = '<svg class="ttd-tab-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><path d="m8.6 10.5 6.8-4"></path><path d="m8.6 13.5 6.8 4"></path></svg>';

      $form['ttd_topics']['combined_open'] = [
        '#markup' => Markup::create('<div class="ttd-combined-metabox ttd-combined-tabbed">
          <div class="ttd-combined-tabs" role="tablist">
            <button type="button" class="ttd-combined-tab ttd-combined-tab-active" data-tab="topics" role="tab" aria-selected="true">' . $analysis_icon . ' Analysis' . ($has_topics ? '<span class="ttd-combined-tab-check">&#10003;</span>' : '<span class="ttd-combined-tab-pending"></span>') . '</button>
            <button type="button" class="ttd-combined-tab" data-tab="seo" role="tab" aria-selected="false">' . $seo_icon . ' SEO Meta' . (($existing_title && $existing_description) ? '<span class="ttd-combined-tab-check">&#10003;</span>' : '<span class="ttd-combined-tab-pending"></span>') . '</button>
            <button type="button" class="ttd-combined-tab" data-tab="social" role="tab" aria-selected="false">' . $social_icon . ' Social Meta' . (($existing_og_title && $existing_og_description) ? '<span class="ttd-combined-tab-check">&#10003;</span>' : '<span class="ttd-combined-tab-pending"></span>') . '</button>
          </div>
          <div class="ttd-combined-panel ttd-combined-panel-active" data-panel="topics" role="tabpanel">'),
        '#weight' => 0,
      ];
    }

    // Render the new Admin Topics Block (WP beta features).
    if ($node->id() && !$analysis_in_progress) {
      $block_manager = \Drupal::service('plugin.manager.block');
      $plugin_block = $block_manager->createInstance('admin_node_topics_block', []);

      // Build the block
      $build = $plugin_block->build();

      if (!empty($build)) {
        $form['ttd_topics']['editor'] = $build;
        $form['ttd_topics']['editor']['#weight'] = 10;
      }
    }
    elseif (!$node->id() && !$analysis_in_progress) {
      $form['ttd_topics']['empty'] = [
        '#markup' => '<p>' . t('Topics will appear here after the first analysis.') . '</p>',
        '#weight' => 10,
      ];
    }

    if ($use_combined_editor) {
      $form['ttd_topics']['topics_panel_close'] = [
        '#markup' => Markup::create('</div><div class="ttd-combined-panel" data-panel="seo" role="tabpanel">'),
        '#weight' => 20,
      ];
    }

    // Add the entity builder to process form values before saving the entity.
    $form['#entity_builders'][] = 'ttd_topics_node_builder';

    if ($node->get('field_ttd_analysis_in_progress')->value) {
      $form['ttd_topics']['analysis_in_progress'] = [
        '#markup' => '
          <div class="ttd-analysis-progress compact" role="status" aria-live="polite" aria-label="' . t('Analysis in progress') . '">
            <div class="ttd-analysis-progress-content">
              <div class="ttd-analysis-spinner" aria-hidden="true"></div>
              <div class="ttd-analysis-text">
                <h4 class="ttd-analysis-title">' . t('Analysis in Progress') . '</h4>
                <p class="ttd-analysis-status">' . t('Analysis in progress') . '<span class="ttd-analysis-dots"><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span></span></p>
              </div>
            </div>
          </div>',
        '#attached' => [
          'library' => ['ttd_topics/analysis_progress'],
          'drupalSettings' => [
            'ttdTopics' => [
              'nodeId' => $node->id(),
              'enableStatusPolling' => TRUE,
              'enableDynamicStatus' => FALSE,
            ],
          ],
        ],
      ];
    }
    else {
      // Existing code for displaying topics...
    }

    // Add Meta Generator section (if enabled in settings).
    if ($meta_gen_enabled && $is_saved && !$node->get('field_ttd_analysis_in_progress')->value) {
      $meta_key = $use_combined_editor ? 'ttd_topics' : 'ttd_meta_generator';

      if (!$use_combined_editor) {
        $form['ttd_meta_generator'] = [
          '#type' => 'details',
          '#title' => t('SEO Meta Generator'),
          '#weight' => 51,
          '#optional' => FALSE,
          '#open' => TRUE,
        ];
      }

      $form['#attached']['library'][] = 'ttd_topics/meta_generator';

      $settings = [
        'nodeId' => $node->id(),
        'postUrl' => ttd_topics_get_node_absolute_url($node),
        'postTitle' => $node->getTitle(),
        'ogImageUrl' => ttd_topics_get_social_meta_image_url($node),
        'apiBase' => '/api/topicalboost/meta',
        'nonce' => \Drupal::csrfToken()->get('ttd_meta_generator'),
        'existingSocialMeta' => ($existing_og_title && $existing_og_description) ? [
          'title' => $existing_og_title,
          'description' => $existing_og_description,
        ] : NULL,
      ];

      if ($existing_title && $existing_description) {
        $settings['existingMeta'] = [
          'title' => $existing_title,
          'description' => $existing_description,
        ];
      }

      $form['#attached']['drupalSettings']['ttdMetaGenerator'] = $settings;

      if (!$has_topics) {
        $form[$meta_key]['no_topics'] = [
          '#markup' => '<p>' . t('Run TopicalBoost analysis first to detect topics, then generate SEO-optimized meta.') . '</p>',
          '#weight' => 30,
        ];
      }
      else {
        if ($use_combined_editor) {
          $form[$meta_key]['meta_wrapper_open'] = [
            '#markup' => Markup::create('<div class="ttd-meta-generator-wrapper">'),
            '#weight' => 25,
          ];
        }

        // Show existing meta if available.
        if ($existing_title && $existing_description) {
          $form[$meta_key]['existing'] = [
            '#markup' => '
              <div class="ttd-meta-existing">
                <h4>' . t('Current Generated Meta') . '</h4>
                <div class="ttd-meta-preview">
                  <div class="ttd-meta-preview-title">' . htmlspecialchars($existing_title, ENT_QUOTES, 'UTF-8') . '</div>
                  <div class="ttd-meta-preview-desc">' . htmlspecialchars($existing_description, ENT_QUOTES, 'UTF-8') . '</div>
                </div>
                <button type="button" class="button ttd-meta-regenerate-btn">' . t('Regenerate') . '</button>
              </div>',
            '#weight' => 28,
          ];
        }

        $form[$meta_key]['container'] = [
          '#type' => 'container',
          '#attributes' => [
            'id' => 'ttd-meta-generator-container',
            'data-node-id' => $node->id(),
          ],
          '#weight' => 30,
        ];

        if ($use_combined_editor) {
          $form[$meta_key]['meta_wrapper_close'] = [
            '#markup' => Markup::create('</div>'),
            '#weight' => 35,
          ];
        }
      }

      if ($use_combined_editor) {
        $form[$meta_key]['social_panel_open'] = [
          '#markup' => Markup::create('</div><div class="ttd-combined-panel" data-panel="social" role="tabpanel">'),
          '#weight' => 40,
        ];

        if (!$has_topics) {
          $form[$meta_key]['social_no_topics'] = [
            '#markup' => '<p>' . t('Run TopicalBoost analysis first to generate social meta.') . '</p>',
            '#weight' => 42,
          ];
        }
        else {
          $form[$meta_key]['social_wrapper_open'] = [
            '#markup' => Markup::create('<div class="ttd-meta-generator-wrapper">'),
            '#weight' => 42,
          ];
          $form[$meta_key]['social_container'] = [
            '#type' => 'container',
            '#attributes' => [
              'id' => 'ttd-social-meta-generator-container',
              'data-node-id' => $node->id(),
            ],
            '#weight' => 44,
          ];
          $form[$meta_key]['social_wrapper_close'] = [
            '#markup' => Markup::create('</div>'),
            '#weight' => 46,
          ];
        }

        $form[$meta_key]['combined_close'] = [
          '#markup' => Markup::create('</div></div>'),
          '#weight' => 50,
        ];
      }
    }

    // Add Schema Images section.
    if ($is_saved && !$node->get('field_ttd_analysis_in_progress')->value) {
      $has_schema_field = $node->hasField('field_ttd_schema_16x9');
      if ($has_schema_field) {
        // Hide the raw schema image fields.
        foreach (['field_ttd_schema_16x9', 'field_ttd_schema_4x3', 'field_ttd_schema_1x1', 'field_ttd_schema_focal_point'] as $hide_field) {
          if (isset($form[$hide_field])) {
            $form[$hide_field]['#access'] = FALSE;
          }
        }

        // Get source image for focal point picker.
        $source_url = ttd_topics_get_node_image_url($node, [
          'field_article_image',
          'field_image',
          'field_featured_image',
          'field_article_banner',
          'field_hero_image',
          'field_media_image',
        ]);

        $form['ttd_schema_images'] = [
          '#type' => 'details',
          '#title' => t('Schema Images'),
          '#weight' => 52,
          '#optional' => FALSE,
          '#open' => TRUE,
        ];

        $focal_html = '';
        if ($source_url) {
          $focal_html = '<div class="ttd-focal-tools">'
            . '<button type="button" class="button button-small ttd-focal-toggle" aria-expanded="false">Adjust crop</button>'
            . ' <span class="ttd-focal-summary">Crop center: x 0.50, y 0.50</span>'
            . '<div class="ttd-focal-panel" hidden>'
            . '<div class="ttd-focal-picker"><img src="' . htmlspecialchars($source_url) . '" alt="Source image for crop adjustment"><div class="ttd-focal-marker" style="left:50%;top:50%"></div></div>'
            . '<div class="ttd-focal-coords">x: 0.50, y: 0.50</div>'
            . '<div class="ttd-focal-help">Click the source image to choose the crop center used when generating schema images.</div>'
            . '</div>'
            . '</div>';
        }

        $form['ttd_schema_images']['widget'] = [
          '#markup' => Markup::create('<div class="ttd-schema-images-wrap" data-nid="' . $node->id() . '">'
            . '<div class="ttd-schema-status">Loading...</div>'
            . '<div class="ttd-schema-formats"></div>'
            . '<div class="ttd-schema-source-info"></div>'
            . $focal_html
            . '<div class="ttd-schema-actions">'
            . '<button type="button" class="button ttd-schema-generate-btn">Generate Schema Images</button>'
            . '<button type="button" class="button ttd-schema-upload-btn">Upload Custom Image</button>'
            . '<input type="file" class="ttd-schema-file-input" accept="image/*">'
            . '<button type="button" class="ttd-schema-clear-btn">Clear Images</button>'
            . '</div>'
            . '</div>'),
        ];

        $form['ttd_schema_images']['#attached']['library'][] = 'ttd_topics/schema_images';
      }
    }
  }
}

/**
 * Get the count of nodes for each TTD Topic term.
 */
function ttd_topics_get_ttd_topic_node_counts($term_ids) {
  if (empty($term_ids)) {
    return [];
  }

  $query = \Drupal::database()->select('taxonomy_index', 'ti');
  $query->addField('ti', 'tid');
  $query->addExpression('COUNT(DISTINCT ti.nid)', 'node_count');
  $query->condition('ti.tid', $term_ids, 'IN');
  $query->groupBy('ti.tid');

  $results = $query->execute()->fetchAllKeyed();

  return $results;
}

/**
 * Entity builder for the node form to map checkbox values to rejected topics.
 */
function ttd_topics_node_builder($entity_type, $entity, &$form, FormStateInterface $form_state) {
  $all_topics = $entity->get('field_ttd_topics')->getValue();
  $current_rejected_topics = $entity->get('field_ttd_rejected_topics')->getValue();
  $new_rejected_topics = [];

  // Get values from both sections (About and Mentions).
  $about_values = $form_state->getValue('about_section') ?? [];
  $mentions_values = $form_state->getValue('mentions_section') ?? [];

  // Process each topic from the form.
  foreach ($all_topics as $topic) {
    if (isset($topic['target_id'])) {
      $topic_id = $topic['target_id'];

      // Check in about_section first, then mentions_section.
      $checkbox_value = NULL;
      if (isset($about_values[$topic_id])) {
        $checkbox_value = $about_values[$topic_id];
      }
      elseif (isset($mentions_values[$topic_id])) {
        $checkbox_value = $mentions_values[$topic_id];
      }

      if ($checkbox_value === 0) {
        $new_rejected_topics[] = ['target_id' => $topic_id];
      }
    }
  }

  // Only update if there's a change in rejected topics.
  if ($new_rejected_topics != $current_rejected_topics) {
    $entity->set('field_ttd_rejected_topics', $new_rejected_topics);
  }
}

/**
 * Attach the topicalboost.styles library to node edit forms.
 * Also hides SEO module UI when configured.
 */
function ttd_topics_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  if (substr($form_id, 0, 5) == 'node_') {
    $form['#attached']['library'][] = 'ttd_topics/ttd_topics.styles';

    // Hide SEO module UI elements when configured.
    $config = \Drupal::config('ttd_topics.settings');
    if ($config->get('hide_seo_module_ui')) {
      // Hide Metatag module form elements.
      $form_object = $form_state->getFormObject();
      $entity = method_exists($form_object, 'getEntity') ? $form_object->getEntity() : NULL;
      if ($entity instanceof NodeInterface) {
        $metatag_field = ttd_topics_get_metatag_field_name($entity);
        if ($metatag_field && isset($form[$metatag_field])) {
          $form[$metatag_field]['#access'] = FALSE;
        }
      }
      // Hide Yoast/Real-time SEO for Drupal form elements.
      foreach (['field_yoast_seo', 'field_seo'] as $seo_field_name) {
        if (isset($form[$seo_field_name])) {
          $form[$seo_field_name]['#access'] = FALSE;
        }
      }
      // Hide Simple XML Sitemap elements.
      if (isset($form['simple_sitemap'])) {
        $form['simple_sitemap']['#access'] = FALSE;
      }
    }
  }
}

/**
 * Helper function to get filtered topics for a node.
 */
function ttd_topics_get_filtered_topics_for_node(EntityInterface $node) {
  $config = \Drupal::config('ttd_topics.settings');
  $min_display_count = (int) ($config->get('post_topic_minimum_display_count') ?? 0);
  $filtered_topics = [];

  // Load the terms from the field_ttd_topics field.
  if (!empty($node->field_ttd_topics)) {
    $rejected_term_ids = $node->hasField('field_ttd_rejected_topics')
      ? array_map('intval', array_column($node->get('field_ttd_rejected_topics')->getValue(), 'target_id'))
      : [];
    $manual_term_ids = $node->hasField('field_manual_topics')
      ? array_map('intval', array_column($node->get('field_manual_topics')->getValue(), 'target_id'))
      : [];
    $term_ids = [];
    foreach ($node->field_ttd_topics as $term_ref) {
      $term = $term_ref->entity;
      if (!$term) {
        continue;
      }
      $tid = (int) $term->id();
      $is_manual = in_array($tid, $manual_term_ids, TRUE);
      $is_hidden = $term->hasField('field_hide') && !$term->get('field_hide')->isEmpty() && (bool) $term->get('field_hide')->value;
      if (!$is_hidden && ($is_manual || !in_array($tid, $rejected_term_ids, TRUE))) {
        $term_ids[] = $term->id();
      }
    }

    // Get the count of nodes for each term.
    $term_counts = ttd_topics_get_topic_node_counts($term_ids);

    // Get salience data for all entities on this node.
    $salience_data = ttd_get_node_salience_data($node->id());

    foreach ($node->field_ttd_topics as $term_ref) {
      $term = $term_ref->entity;
      if ($term) {
        $tid = (int) $term->id();
        $is_manual = in_array($tid, $manual_term_ids, TRUE);
        $is_hidden = $term->hasField('field_hide') && !$term->get('field_hide')->isEmpty() && (bool) $term->get('field_hide')->value;
        if ($is_hidden) {
          continue;
        }

        // Skip rejected topics.
        if (!$is_manual && in_array($tid, $rejected_term_ids, TRUE)) {
          continue;
        }

        $count = $term_counts[$tid] ?? 0;
        $ttd_id = $term->hasField('field_ttd_id') && !$term->get('field_ttd_id')->isEmpty()
          ? (int) $term->get('field_ttd_id')->value
          : 0;
        $entity_salience = $salience_data[$ttd_id] ?? ['salience_score' => NULL, 'salience_category' => NULL];
        $tier = $entity_salience['salience_category'] ?: 'mentions';
        if (!in_array($tier, ['mainEntity', 'about', 'mentions'], TRUE)) {
          $tier = 'mentions';
        }
        $is_force_show = $term->hasField('field_force_show') && !$term->get('field_force_show')->isEmpty() && (bool) $term->get('field_force_show')->value;
        $is_high_salience = in_array($tier, ['mainEntity', 'about'], TRUE);

        // Match WordPress: manual, forced, and main/about topics bypass threshold.
        if ($is_manual || $is_force_show || $is_high_salience || $count >= $min_display_count) {
          $filtered_topics[] = [
            'term' => $term,
            'count' => $count,
            'salience_score' => $entity_salience['salience_score'],
            'salience_category' => $tier,
            'salience_tier' => $tier,
            'is_manual' => $is_manual,
          ];
        }
      }
    }

    // Match WordPress ordering: mainEntity, about, mentions, then configured sort.
    $sort_order = $config->get('frontend_sort_order') ?: 'salience';
    $tier_priority = ['mainEntity' => 0, 'about' => 1, 'mentions' => 2];
    usort($filtered_topics, function ($a, $b) use ($sort_order, $tier_priority) {
      $tier_a = $tier_priority[$a['salience_category'] ?? 'mentions'] ?? 2;
      $tier_b = $tier_priority[$b['salience_category'] ?? 'mentions'] ?? 2;
      if ($tier_a !== $tier_b) {
        return $tier_a <=> $tier_b;
      }

      if ($sort_order === 'alphabetical') {
        return strcasecmp($a['term']->label(), $b['term']->label());
      }

      $score_a = $a['salience_score'] ?? -1;
      $score_b = $b['salience_score'] ?? -1;
      if ($score_b !== $score_a) {
        return $score_b <=> $score_a;
      }

      return strcasecmp($a['term']->label(), $b['term']->label());
    });
  }

  return $filtered_topics;
}

/**
 * Implements hook_node_view().
 */
function ttd_topics_node_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  // Check if this is an enabled content type.
  if (in_array($entity->getType(), $enabled_content_types)) {
    // Attach the frontend library.
    $build['#attached']['library'][] = 'ttd_topics/ttd_topics.frontend';

    if ($view_mode == 'full') {
      $topics_display = ttd_topics_build_frontend_topics_display($entity, TRUE);
      if (!empty($topics_display)) {
        $topics_display['#weight'] = 100;
        $build['topicalboost_display'] = $topics_display;
      }
    }
  }
}

/**
 * Builds the shared frontend topics display render array for a node.
 *
 * @param \Drupal\node\NodeInterface $node
 *   The node whose topics should be rendered.
 * @param bool $respect_automatic_mentions
 *   Whether to obey the automatic frontend insertion setting.
 *
 * @return array
 *   A render array, or an empty array when nothing should render.
 */
function ttd_topics_build_frontend_topics_display(NodeInterface $node, bool $respect_automatic_mentions = FALSE): array {
  if (!$node->hasField('field_ttd_topics')) {
    return [];
  }

  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
  if (!in_array($node->getType(), $enabled_content_types, TRUE)) {
    return [];
  }

  if (!$config->get('enable_frontend') && !ttd_topics_account_has_required_permission()) {
    return [];
  }

  if ($respect_automatic_mentions && !($config->get('enable_automatic_mentions') ?? TRUE) && !ttd_topics_account_has_required_permission()) {
    return [];
  }

  $filtered_topics = ttd_topics_get_filtered_topics_for_node($node);
  if (empty($filtered_topics)) {
    return [];
  }

  $cache_tags = $node->getCacheTags();
  foreach ($filtered_topics as $topic) {
    if (!empty($topic['term']) && $topic['term'] instanceof EntityInterface) {
      $cache_tags = \Drupal\Core\Cache\Cache::mergeTags($cache_tags, $topic['term']->getCacheTags());
    }
  }
  $cache_tags = \Drupal\Core\Cache\Cache::mergeTags($cache_tags, ['config:ttd_topics.settings']);

  return [
    '#theme' => 'topicalboost_display',
    '#node' => $node,
    '#filtered_topics' => $filtered_topics,
    '#topics_list_label' => $config->get('topics_list_label'),
    '#maximum_visible_post_topics' => $config->get('maximum_visible_post_topics') ?: 5,
    '#options' => [
      'frontend_filter_mode' => $config->get('frontend_filter_mode') ?: 'mentions_behind_toggle',
    ],
    '#taxonomy_label_singular' => $config->get('taxonomy_label_singular') ?: 'Topic',
    '#taxonomy_label_plural' => $config->get('taxonomy_label_plural') ?: 'Topics',
    '#attached' => [
      'library' => ['ttd_topics/ttd_topics.frontend'],
    ],
    '#cache' => [
      'contexts' => ['route', 'user.permissions'],
      'tags' => $cache_tags,
    ],
  ];
}

/**
 * Auto-link topic names in rendered content body.
 *
 * For each about/mainEntity topic on the node, finds the first occurrence
 * in the rendered body text and replaces it with a link to the topic page.
 *
 * @param string $text
 *   The rendered HTML body text.
 * @param \Drupal\Core\Entity\EntityInterface $node
 *   The node entity.
 *
 * @return string
 *   The text with topic names auto-linked.
 */
function ttd_topics_auto_link_content($text, EntityInterface $node) {
  if (empty($text)) {
    return $text;
  }

  $filtered_topics = ttd_topics_get_filtered_topics_for_node($node);
  if (empty($filtered_topics)) {
    return $text;
  }

  // Collect only about/mainEntity topics.
  $link_topics = [];
  foreach ($filtered_topics as $topic_data) {
    $category = $topic_data['salience_category'] ?? 'mentions';
    if (in_array($category, ['about', 'mainEntity'])) {
      $term = $topic_data['term'];
      $link_topics[] = [
        'name' => $term->label(),
        'url' => $term->toUrl()->toString(),
      ];
    }
  }

  if (empty($link_topics)) {
    return $text;
  }

  // Sort by name length (longest first) to avoid partial matches.
  usort($link_topics, function ($a, $b) {
    return strlen($b['name']) - strlen($a['name']);
  });

  // Track which positions have been linked to avoid overlapping replacements.
  $linked_positions = [];

  foreach ($link_topics as $topic) {
    $name = preg_quote($topic['name'], '/');
    // Match word boundaries, skip inside HTML tags.
    $pattern = '/(?<![<\/\w])(\b' . $name . '\b)(?![^<]*>)/iu';

    $text = preg_replace_callback($pattern, function ($matches) use ($topic, &$linked_positions) {
      // Only replace the first occurrence.
      static $replaced = [];
      $key = $topic['url'];
      if (isset($replaced[$key])) {
        return $matches[0];
      }
      $replaced[$key] = TRUE;
      return '<a href="' . htmlspecialchars($topic['url'], ENT_QUOTES, 'UTF-8') . '" class="topicalboost-auto-link">' . $matches[1] . '</a>';
    }, $text, -1);
  }

  return $text;
}

/**
 * Implements hook_preprocess_field() for body fields.
 *
 * Auto-links topic names in body content when the setting is enabled.
 */
function ttd_topics_preprocess_field(&$variables) {
  if ($variables['field_name'] !== 'body') {
    return;
  }
  if ($variables['element']['#view_mode'] !== 'full') {
    return;
  }

  $config = \Drupal::config('ttd_topics.settings');
  if (!$config->get('auto_link_topics')) {
    return;
  }

  $entity = $variables['element']['#object'] ?? NULL;
  if (!$entity || !($entity instanceof NodeInterface)) {
    return;
  }

  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
  if (!in_array($entity->getType(), $enabled_content_types)) {
    return;
  }

  foreach ($variables['items'] as &$item) {
    if (isset($item['content']['#text'])) {
      $item['content']['#text'] = ttd_topics_auto_link_content($item['content']['#text'], $entity);
    }
  }
}

/**
 * Implements hook_element_info_alter().
 */
function ttd_topics_element_info_alter(array &$info) {
  $info['topicalboost_checkboxes'] = [
    '#input' => TRUE,
    '#process' => [
      ['\Drupal\ttd_topics\Element\TtdTopicsCheckboxes', 'processTtdTopicsCheckboxes'],
    ],
    '#theme_wrappers' => ['checkboxes'],
  ];
}

/**
 * Filters HTML content into clean analysis text while preserving structure.
 *
 * Mirrors the WordPress plugin's filter_text() behavior for paragraphs,
 * headings, lists, shortcodes, Gutenberg comments, and HTML entities.
 */
function ttd_topics_filter_text(string $text): string {
  if ($text === '') {
    return '';
  }

  // Remove Gutenberg block comments and WordPress-style shortcodes.
  $text = preg_replace('/<!--\s*\/?wp:[^>]*-->/i', "\n\n", $text);
  $text = preg_replace('/\[(\w[\w-]*)(?:[^\]]*)\].*?\[\/\1\]/s', ' ', $text);
  $text = preg_replace('/\[[^\]]+\]/', ' ', $text);

  // Convert block boundaries to line breaks before stripping tags.
  $block_tags = 'p|div|section|article|header|footer|blockquote|h[1-6]|ul|ol|table|tr';
  $text = preg_replace('/<br\s*\/?>/i', "\n", $text);
  $text = preg_replace('/<li\b[^>]*>/i', '', $text);
  $text = preg_replace('/<\/li\s*>/i', "\n", $text);
  $text = preg_replace('/<(' . $block_tags . ')\b[^>]*>/i', "\n\n", $text);
  $text = preg_replace('/<\/(' . $block_tags . ')\s*>/i', "\n\n", $text);

  $text = strip_tags($text);
  $text = html_entity_decode($text, ENT_QUOTES | ENT_HTML5, 'UTF-8');
  $text = preg_replace('/[ \t\x{00A0}]+/u', ' ', $text);
  $text = preg_replace('/[ \t\r]*\n[ \t\r]*/', "\n", $text);
  $text = preg_replace('/\n{3,}/', "\n\n", $text);

  return trim($text);
}

/**
 * Merge fresh API topic IDs with manual topics using WordPress parity rules.
 *
 * Manual topics survive reanalysis unless the API now returns the same TTD
 * entity, in which case the topic is promoted to API-managed and removed from
 * the manual list. Stale API topics are not preserved.
 */
function ttd_topics_merge_analysis_topic_ids_with_manual(NodeInterface $node, array $api_term_ids, array $api_ttd_ids): array {
  $api_term_ids = array_values(array_unique(array_map('intval', $api_term_ids)));
  $api_ttd_lookup = array_fill_keys(array_map('intval', $api_ttd_ids), TRUE);

  if (!$node->hasField('field_manual_topics')) {
    return $api_term_ids;
  }

  $manual_term_ids = array_map('intval', array_column($node->get('field_manual_topics')->getValue(), 'target_id'));
  $preserved_manual_ids = [];
  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');

  foreach ($manual_term_ids as $manual_term_id) {
    $term = $term_storage->load($manual_term_id);
    if (!$term) {
      continue;
    }

    $manual_ttd_id = $term->hasField('field_ttd_id') && !$term->get('field_ttd_id')->isEmpty()
      ? (int) $term->get('field_ttd_id')->value
      : 0;
    if ($manual_ttd_id && isset($api_ttd_lookup[$manual_ttd_id])) {
      continue;
    }

    $preserved_manual_ids[] = $manual_term_id;
  }

  $node->set('field_manual_topics', array_map(static fn($tid) => ['target_id' => $tid], array_values(array_unique($preserved_manual_ids))));

  return array_values(array_unique(array_merge($api_term_ids, $preserved_manual_ids)));
}

