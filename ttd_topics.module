/**
 * Builds standard TopicalBoost API headers.
 */
function ttd_topics_api_headers($api_key) {
  $headers = [
    'Content-Type' => 'application/json',
    'x-api-key' => $api_key,
  ];

  $site_base_url = ttd_topics_get_site_base_url();
  if ($site_base_url !== '') {
    $headers['x-tb-site-url'] = $site_base_url;
  }

  return $headers;
}

/**
 * Returns a stable public site base URL for background API requests.
 */
function ttd_topics_get_site_base_url() {
  $configured_url = trim((string) \Drupal::config('ttd_topics.settings')->get('site_base_url'));
  if ($configured_url !== '') {
    return ttd_topics_normalize_site_base_url($configured_url);
  }

  if (!empty($GLOBALS['base_url'])) {
    $base_url = ttd_topics_normalize_site_base_url((string) $GLOBALS['base_url']);
    if ($base_url !== '' && !ttd_topics_uses_default_host($base_url)) {
      return $base_url;
    }
  }

  $request_url = \Drupal::request()->getSchemeAndHttpHost();
  if ($request_url !== '' && !ttd_topics_uses_default_host($request_url)) {
    return rtrim($request_url, '/');
  }

  return '';
}

/**
 * Builds an absolute node URL without leaking Drupal CLI's default host.
 */
function ttd_topics_get_node_absolute_url(NodeInterface $node) {
  $absolute_url = $node->toUrl()->setAbsolute()->toString();
  if (!ttd_topics_uses_default_host($absolute_url)) {
    return $absolute_url;
  }

  $site_base_url = ttd_topics_get_site_base_url();
  if ($site_base_url === '') {
    return $absolute_url;
  }

  $relative_url = $node->toUrl()->toString();
  if (preg_match('/^https?:\/\//i', $relative_url)) {
    $parts = parse_url($relative_url);
    $relative_url = ($parts['path'] ?? '/')
      . (isset($parts['query']) ? '?' . $parts['query'] : '')
      . (isset($parts['fragment']) ? '#' . $parts['fragment'] : '');
  }

  return rtrim($site_base_url, '/') . '/' . ltrim($relative_url, '/');
}

/**
 * Returns the best social preview image URL for a node.
 */
function ttd_topics_get_social_meta_image_url(NodeInterface $node) {
  return ttd_topics_get_node_image_url($node, [
    'field_ttd_schema_16x9',
    'field_article_image',
    'field_image',
    'field_featured_image',
    'field_article_banner',
    'field_hero_image',
    'field_media_image',
  ]);
}

/**
 * Returns an absolute URL from the first populated image or media field.
 */
function ttd_topics_get_node_image_url(NodeInterface $node, array $field_names) {
  foreach ($field_names as $field_name) {
    $file = ttd_topics_get_node_image_file($node, $field_name);
    if ($file && method_exists($file, 'getFileUri')) {
      return \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri());
    }
  }

  return '';
}

/**
 * Resolves a node image/media field to its underlying file entity.
 */
function ttd_topics_get_node_image_file(NodeInterface $node, $field_name) {
  if (!$node->hasField($field_name) || $node->get($field_name)->isEmpty()) {
    return NULL;
  }

  $referenced = $node->get($field_name)->entity;
  if (!$referenced) {
    return NULL;
  }

  if ($referenced->getEntityTypeId() === 'file') {
    return $referenced;
  }

  if ($referenced->getEntityTypeId() === 'media' && method_exists($referenced, 'getSource')) {
    $media_source = $referenced->getSource();
    $src_field = $media_source->getConfiguration()['source_field'] ?? 'field_media_image';
    if ($referenced->hasField($src_field) && !$referenced->get($src_field)->isEmpty()) {
      return $referenced->get($src_field)->entity;
    }
  }

  return NULL;
}

/**
 * Normalizes a configured site base URL.
 */
function ttd_topics_normalize_site_base_url($url) {
  $url = trim((string) $url);
  if ($url === '') {
    return '';
  }

  if (!preg_match('/^https?:\/\//i', $url)) {
    $url = 'https://' . $url;
  }

  $host = parse_url($url, PHP_URL_HOST);
  if (!$host) {
    return '';
  }

  $scheme = parse_url($url, PHP_URL_SCHEME) ?: 'https';
  $port = parse_url($url, PHP_URL_PORT);
  $path = trim((string) (parse_url($url, PHP_URL_PATH) ?: ''), '/');

  return $scheme . '://' . $host
    . ($port ? ':' . $port : '')
    . ($path !== '' ? '/' . $path : '');
}

/**
 * Detects Drupal's placeholder CLI host.
 */
function ttd_topics_uses_default_host($url) {
  $host = strtolower((string) parse_url((string) $url, PHP_URL_HOST));
  return $host === '' || $host === 'default';
}

