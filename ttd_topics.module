    'isbn_13' => ['label' => 'ISBN-13', 'format' => 'text'],
    'twitter_username' => ['label' => 'Twitter Username', 'format' => 'text'],
    'facebook_id' => ['label' => 'Facebook ID', 'format' => 'text'],
    'linkedin_personal_profile_id' => ['label' => 'LinkedIn Personal Profile ID', 'format' => 'text'],
    'schema_types' => ['label' => 'Schema Types', 'format' => 'list'],
    'wb_categories' => ['label' => 'WB Categories', 'format' => 'list'],
  ];

  $ordered_keys = array_unique(array_merge(array_keys($field_config), array_keys($entity_info)));
  foreach ($ordered_keys as $key) {
    if (in_array($key, $skip_fields)) {
      continue;
    }
    if (!array_key_exists($key, $entity_info)) {
      continue;
    }
    $value = $entity_info[$key];

    // Skip empty or null values.
    if (empty($value) && $value !== '0') {
      continue;
    }

    $config = $field_config[$key] ?? [
      'label' => ucwords(str_replace('_', ' ', $key)),
      'format' => 'text',
    ];

    $rows[] = [
      'field' => $config['label'],
      'value' => [
        'data' => [
          '#type' => 'markup',
          '#markup' => ttd_topics_format_entity_field_value($value, $config['format'], $entity_info),
        ],
      ],
    ];
  }

  return $rows;
}

/**
 * Formats an entity data value for display on topic edit forms.
 *
 * @param mixed $value
 *   Entity field value.
 * @param string $format
 *   Display format: text, list, url, or image.
 * @param array $entity_info
 *   Full entity row, used for image alt text.
 *
 * @return string
 *   Safe HTML markup.
 */
function ttd_topics_format_entity_field_value($value, $format, array $entity_info) {
  if (is_array($value)) {
    $value = implode(', ', array_filter($value, static function ($item) {
      return $item !== NULL && $item !== '';
    }));
  }
  elseif (is_object($value)) {
    $value = json_encode($value, JSON_PRETTY_PRINT);
  }

  $value = (string) $value;
  if ($format === 'text' && (str_starts_with(trim($value), '[') || str_starts_with(trim($value), '{'))) {
    $decoded = json_decode($value);
    if ($decoded !== NULL) {
      $value = json_encode($decoded, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES);
    }
  }

  $escaped = htmlspecialchars($value, ENT_QUOTES, 'UTF-8');
  $url = filter_var($value, FILTER_VALIDATE_URL) ? $value : NULL;

  if ($format === 'image' && $url) {
    $safe_url = htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
    $alt = htmlspecialchars((string) ($entity_info['name'] ?? $entity_info['wb_name'] ?? $entity_info['kg_name'] ?? ''), ENT_QUOTES, 'UTF-8');
    return '<div class="ttd-entity-image"><img src="' . $safe_url . '" alt="' . $alt . '" style="max-width: 180px; max-height: 120px; display: block; margin-bottom: 6px;" /><a href="' . $safe_url . '" target="_blank" rel="noopener noreferrer">' . t('View full image') . '</a></div>';
  }

  if ($format === 'url' && $url) {
    $safe_url = htmlspecialchars($url, ENT_QUOTES, 'UTF-8');
    return '<a href="' . $safe_url . '" target="_blank" rel="noopener noreferrer">' . $escaped . '</a>';
  }

  if ($format === 'list') {
    return $escaped;
  }

  return '<pre>' . $escaped . '</pre>';
}

/**
 * Implements hook_entity_access().
 */
function ttd_topics_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  if ($entity->getEntityTypeId() === 'taxonomy_term' && $entity->bundle() === 'ttd_topics') {
    if ($operation === 'view' && $entity->hasField('field_hide')) {
      // Get minimum display count from config.
      $config = \Drupal::config('ttd_topics.settings');
      $min_display_count = $config->get('post_topic_minimum_display_count');
      $frontend_enabled = (bool) $config->get('enable_frontend');

      // Get post count for this term.
      $count = \Drupal::database()->select('taxonomy_index', 'ti')
        ->condition('tid', $entity->id())
        ->countQuery()
        ->execute()
        ->fetchField();

      // Return 404 if public display is disabled and the user lacks access.
      if (!$frontend_enabled && !ttd_topics_account_has_required_permission($account)) {
        return AccessResult::forbidden()
          ->addCacheableDependency($entity)
          ->addCacheContexts(['user.permissions']);
      }

      // Return 404 if hidden OR below minimum count for anonymous users.
      if (($entity->get('field_hide')->value || $count < $min_display_count) && $account->isAnonymous()) {
        return AccessResult::forbidden()->addCacheableDependency($entity);
      }
    }
  }
  return AccessResult::neutral();
}

/**
 * AJAX callback for the "Run Analysis" button.
 */
function ttd_topics_run_analysis_ajax_callback(array &$form, FormStateInterface $form_state) {
  $node = $form_state->getFormObject()->getEntity();
  $identifier = $node->id() ? $node->id() : $node->uuid();

  try {
    $queue_storage = \Drupal::entityTypeManager()->getStorage('advancedqueue_queue');
    $queue = $queue_storage->load('ttd_topics_analysis');
    if ($queue) {
      $job = Job::create('ttd_topics_analysis', [
        'node_id' => $identifier,
        'force_analysis' => TRUE,
      ]);
      $queue->enqueueJob($job);

      // Set the analysis in progress flag.
      $node->set('field_ttd_analysis_in_progress', TRUE);
      $node->save();

      $message = t('Analysis has been queued and will run in the background. Please check back in a few minutes.');
      $queued = TRUE;
    }
    else {
      $message = t('Error: TTD Topics analysis queue not found.');
      $queued = FALSE;
    }
  }
  catch (\Exception $e) {
    $message = t('Error queueing TTD Topics analysis: @message', ['@message' => $e->getMessage()]);
    $queued = FALSE;
    \Drupal::logger('topicalboost')->error('Error queueing TTD Topics analysis job: @message', ['@message' => $e->getMessage()]);
  }

  $response = new AjaxResponse();
  if ($queued) {
    $response->addCommand(new ReplaceCommand(
      '#ttd-topics-run-analysis-wrapper',
      [
        '#type' => 'container',
        '#attributes' => ['id' => 'ttd-topics-run-analysis-wrapper'],
        'progress' => [
          '#markup' => '
            <div class="ttd-analysis-progress compact" role="status" aria-live="polite" aria-label="' . t('Analysis in progress') . '">
              <div class="ttd-analysis-progress-content">
                <div class="ttd-analysis-spinner" aria-hidden="true"></div>
                <div class="ttd-analysis-text">
                  <h4 class="ttd-analysis-title">' . t('Running TopicalBoost Analysis') . '</h4>
                  <p class="ttd-analysis-status">' . $message . '<span class="ttd-analysis-dots"><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span><span class="ttd-analysis-dot"></span></span></p>
                </div>
              </div>
            </div>',
        ],
        '#attached' => [
          'library' => ['ttd_topics/analysis_progress'],
          'drupalSettings' => [
            'ttdTopics' => [
              'nodeId' => $node->id(),
              'enableStatusPolling' => TRUE,
              'enableDynamicStatus' => FALSE,
            ],
          ],
        ],
      ]
    ));
  }
  else {
    $response->addCommand(new ReplaceCommand(
      '#ttd-topics-run-analysis-wrapper',
      '<div id="ttd-topics-run-analysis-wrapper"><div class="messages messages--error"><p>' . $message . '</p></div></div>'
    ));
  }

  return $response;
}

/**
 * Checks whether TopicalBoost is enabled for a node bundle.
 */
function ttd_topics_node_is_enabled(NodeInterface $node, $config = NULL): bool {
  $config = $config ?: \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
  return in_array($node->bundle(), $enabled_content_types, TRUE);
}

/**
 * Gets the Metatag field name for a node, regardless of local machine name.
 */
function ttd_topics_get_metatag_field_name(NodeInterface $node): ?string {
  foreach (['field_meta_tags', 'field_metatag'] as $field_name) {
    if ($node->hasField($field_name)) {
      return $field_name;
    }
  }

  foreach ($node->getFieldDefinitions() as $field_name => $definition) {
    if ($definition->getType() === 'metatag') {
      return $field_name;
    }
  }

  return NULL;
}

/**
 * Checks whether TopicalBoost should emit generated SEO tags directly.
 */
function ttd_topics_should_emit_generated_meta(NodeInterface $node): bool {
  $module_handler = \Drupal::moduleHandler();

  if ($module_handler->moduleExists('metatag') && ttd_topics_get_metatag_field_name($node) !== NULL) {
    return FALSE;
  }

  if ($module_handler->moduleExists('yoast_seo') && $node->hasField('field_yoast_seo')) {
    return FALSE;
  }

  return TRUE;
}

/**
 * Gets generated SEO/social values stored by TopicalBoost for a node.
 */
function ttd_topics_get_generated_meta_values(NodeInterface $node): array {
  $title = $node->hasField('field_ttd_generated_meta_title')
    ? trim((string) $node->get('field_ttd_generated_meta_title')->value)
    : '';
  $description = $node->hasField('field_ttd_generated_meta_desc')
    ? trim((string) $node->get('field_ttd_generated_meta_desc')->value)
    : '';
  $og_title = $node->hasField('field_ttd_generated_og_title')
    ? trim((string) $node->get('field_ttd_generated_og_title')->value)
    : '';
  $og_description = $node->hasField('field_ttd_generated_og_desc')
    ? trim((string) $node->get('field_ttd_generated_og_desc')->value)
    : '';
  $canonical_url = '';

  try {
    $canonical_url = $node->toUrl('canonical', ['absolute' => TRUE])->toString();
  }
  catch (\Exception $e) {
    $canonical_url = '';
  }

  return [
    'title' => $title,
    'description' => $description,
    'og_title' => $og_title !== '' ? $og_title : $title,
    'og_description' => $og_description !== '' ? $og_description : $description,
    'canonical_url' => $canonical_url,
  ];
}

/**
 * Emits direct frontend meta tags when no SEO module can render them.
 */
function ttd_topics_attach_generated_meta(array &$attachments, NodeInterface $node): void {
  $meta = ttd_topics_get_generated_meta_values($node);

  $tag_definitions = [
    'topicalboost_meta_description' => ['meta', ['name' => 'description', 'content' => $meta['description']]],
    'topicalboost_og_title' => ['meta', ['property' => 'og:title', 'content' => $meta['og_title']]],
    'topicalboost_og_description' => ['meta', ['property' => 'og:description', 'content' => $meta['og_description']]],
    'topicalboost_og_url' => ['meta', ['property' => 'og:url', 'content' => $meta['canonical_url']]],
    'topicalboost_twitter_card' => ['meta', ['name' => 'twitter:card', 'content' => 'summary_large_image']],
    'topicalboost_twitter_title' => ['meta', ['name' => 'twitter:title', 'content' => $meta['og_title']]],
    'topicalboost_twitter_description' => ['meta', ['name' => 'twitter:description', 'content' => $meta['og_description']]],
    'topicalboost_twitter_url' => ['meta', ['name' => 'twitter:url', 'content' => $meta['canonical_url']]],
  ];

  foreach ($tag_definitions as $key => [$tag, $attributes]) {
    $content = $attributes['content'] ?? $attributes['href'] ?? '';
    if ($content === '') {
      continue;
    }

    $attachments['#attached']['html_head'][] = [
      [
        '#type' => 'html_tag',
        '#tag' => $tag,
        '#attributes' => $attributes,
      ],
      $key,
    ];
  }

  $attachments['#cache']['contexts'] = Cache::mergeContexts($attachments['#cache']['contexts'] ?? [], ['route']);
  $attachments['#cache']['tags'] = Cache::mergeTags($attachments['#cache']['tags'] ?? [], $node->getCacheTags());
}

/**
 * Implements hook_preprocess_html().
 *
 * Adds skeleton style body class if enabled.
 */
function ttd_topics_preprocess_html(&$variables) {
  $config = \Drupal::config('ttd_topics.settings');
  if ($config->get('skeleton_style')) {
    $variables['attributes']['class'][] = 'ttd-skeleton-style';
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  if ($node instanceof NodeInterface && ttd_topics_node_is_enabled($node, $config) && ttd_topics_should_emit_generated_meta($node)) {
    $meta = ttd_topics_get_generated_meta_values($node);
    if ($meta['title'] !== '') {
      if (isset($variables['head_title']) && is_array($variables['head_title'])) {
        $variables['head_title']['title'] = $meta['title'];
      }
      else {
        $variables['head_title'] = $meta['title'];
      }
    }
  }
}

/**
 * Implements hook_page_attachments().
 */
function ttd_topics_page_attachments(array &$attachments) {
  // Attach error telemetry JS on admin pages when enabled.
  $config = \Drupal::config('ttd_topics.settings');
  if ($config->get('error_telemetry_enabled') ?? TRUE) {
    $is_admin = \Drupal::service('router.admin_context')->isAdminRoute();
    if ($is_admin) {
      $attachments['#attached']['library'][] = 'ttd_topics/error_telemetry';
    }
  }

  $node = \Drupal::routeMatch()->getParameter('node');

  if ($node instanceof NodeInterface && ttd_topics_node_is_enabled($node, $config)) {
    if (ttd_topics_should_emit_generated_meta($node)) {
      ttd_topics_attach_generated_meta($attachments, $node);
    }

    try {
      $debug = (bool) $config->get('debug_mode');
      if ($debug) {
        \Drupal::logger('topicalboost')->debug('Starting schema generation for node @nid', ['@nid' => $node->id()]);
      }

      $schema_generator = \Drupal::service('ttd_topics.schema_generator');
      $schema_data = $schema_generator->getNodeTopicsSchema($node->id());

      if ($debug) {
        \Drupal::logger('topicalboost')->debug('Schema data: @data', ['@data' => print_r($schema_data, TRUE)]);
      }

      if (!empty($schema_data) && !empty($schema_data['@graph'])) {
        $attachments['#attached']['html_head'][] = [
          [
            '#type' => 'html_tag',
            '#tag' => 'script',
            '#value' => json_encode($schema_data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES),
            '#attributes' => [
              'type' => 'application/ld+json',
              'class' => 'schema-graph',
            ],
          ],
          'topicalboost_schema',
        ];
      }
    }
    catch (\Exception $e) {
      \Drupal::logger('topicalboost')->error('Schema generation error: @message', [
        '@message' => $e->getMessage(),
        '@trace' => $e->getTraceAsString(),
      ]);
    }
  }

  $term = \Drupal::routeMatch()->getParameter('taxonomy_term');
  if ($term instanceof Term && $term->bundle() === 'ttd_topics') {
    try {
      $schema_generator = \Drupal::service('ttd_topics.schema_generator');
      $schema_data = $schema_generator->getTopicArchiveSchema($term);
      if (!empty($schema_data) && !empty($schema_data['@graph'])) {
        $attachments['#attached']['html_head'][] = [
          [
            '#type' => 'html_tag',
            '#tag' => 'script',
            '#value' => json_encode($schema_data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES),
            '#attributes' => [
              'type' => 'application/ld+json',
              'class' => 'schema-graph topicalboost-topic-archive-schema',
            ],
          ],
          'topicalboost_topic_archive_schema',
        ];
      }
    }
    catch (\Exception $e) {
      \Drupal::logger('topicalboost')->error('Topic archive schema generation error: @message', [
        '@message' => $e->getMessage(),
      ]);
    }
  }
}

/**
 * Implements hook_simple_sitemap_links_alter().
 */
function ttd_topics_simple_sitemap_links_alter(array &$links) {
  // Get minimum display count from config.
  $config = \Drupal::config('ttd_topics.settings');
  $min_display_count = $config->get('post_topic_minimum_display_count');

  foreach ($links as $key => $link) {
    // Check if this is a taxonomy term link for topicalboost.
    if (isset($link['entity_info'])
        && $link['entity_info']['entity_type'] === 'taxonomy_term'
        && $link['entity_info']['bundle'] === 'topicalboost') {

      $term = \Drupal::entityTypeManager()
        ->getStorage('taxonomy_term')
        ->load($link['entity_info']['id']);

      if ($term) {
        // Check if term is hidden.
        if ($term->get('field_hide')->value) {
          unset($links[$key]);
          continue;
        }

        // Check post count.
        $count = \Drupal::database()->select('taxonomy_index', 'ti')
          ->condition('tid', $term->id())
          ->countQuery()
          ->execute()
          ->fetchField();

        if ($count < $min_display_count) {
          unset($links[$key]);
        }
      }
    }
  }
}

/**
 * Get node counts for topic terms.
 *
 * @param array $term_ids
 *   Array of term IDs.
 *
 * @return array
 *   Array of term ID => count pairs.
 */
function ttd_topics_get_topic_node_counts(array $term_ids) {
  if (empty($term_ids)) {
    return [];
  }

  $database = \Drupal::database();
  $query = $database->select('taxonomy_index', 'ti')
    ->fields('ti', ['tid'])
    ->condition('tid', $term_ids, 'IN')
    ->groupBy('tid');
  $query->addExpression('COUNT(nid)', 'count');

  $results = $query->execute()->fetchAllKeyed();

  // Ensure all term IDs are present in the result.
  $counts = [];
  foreach ($term_ids as $tid) {
    $counts[$tid] = isset($results[$tid]) ? (int) $results[$tid] : 0;
  }

  return $counts;
}

/**
 * Implements hook_form_FORM_ID_alter() for taxonomy_overview_terms.
 *
 * Adds a search filter and improved overview.
 */
function ttd_topics_form_taxonomy_overview_terms_alter(&$form, FormStateInterface $form_state, $form_id) {
  $vocabulary = $form_state->getBuildInfo()['args'][0] ?? NULL;

  if ($vocabulary && $vocabulary->id() === 'ttd_topics') {
    // Hide the default terms table to avoid duplication.
    if (isset($form['terms'])) {
      $form['terms']['#access'] = FALSE;
    }

    // Add search filter form.
    $search = \Drupal::request()->query->get('search', '');
    $min_posts = \Drupal::request()->query->get('min_posts', '');

    $form['search_filter'] = [
      '#type' => 'details',
      '#title' => t('Filter topics'),
      '#open' => TRUE,
      '#weight' => -100,
      '#attributes' => ['class' => ['container-inline']],
    ];

    $form['search_filter']['search'] = [
      '#type' => 'search',
      '#title' => t('Search'),
      '#title_display' => 'invisible',
      '#placeholder' => t('Filter by topic name...'),
      '#default_value' => $search,
      '#size' => 25,
    ];

    $form['search_filter']['min_posts'] = [
      '#type' => 'select',
      '#title' => t('Minimum posts'),
      '#title_display' => 'invisible',
      '#options' => [
        '' => t('Any post count'),
        '1' => t('1+ posts'),
        '5' => t('5+ posts'),
        '10' => t('10+ posts'),
        '25' => t('25+ posts'),
        '50' => t('50+ posts'),
        '100' => t('100+ posts'),
      ],
      '#default_value' => $min_posts,
    ];

    $form['search_filter']['submit'] = [
      '#type' => 'submit',
      '#value' => t('Filter'),
      '#submit' => ['ttd_topics_search_submit'],
      '#button_type' => 'primary',
    ];

    if (!empty($search) || !empty($min_posts)) {
      $form['search_filter']['reset'] = [
        '#type' => 'submit',
        '#value' => t('Reset'),
        '#submit' => ['ttd_topics_search_reset'],
      ];
    }

    // Load the controller output.
    $controller = \Drupal::service('class_resolver')->getInstanceFromDefinition('Drupal\\ttd_topics\\Controller\\TtdTopicsController');
    $overview_build = $controller->overviewPage();

    // Insert our overview near the top.
    $form['topicalboost_overview_custom'] = $overview_build + ['#weight' => -50];

    // Remove all the default taxonomy form elements that aren't needed.
    $elements_to_hide = [
      'description',
      '#description',
      'pager',
      'actions',
      'reset_alphabetical',
    ];

    foreach ($elements_to_hide as $element) {
      if (isset($form[$element])) {
        unset($form[$element]);
      }
    }

    // Also try to remove any description attached to the form itself.
    if (isset($form['#description'])) {
      unset($form['#description']);
    }

    // Hide the drag-and-drop help text that appears below the table.
    if (isset($form['#suffix'])) {
      $form['#suffix'] = '';
    }

    // Remove any other help text elements that might contain the drag-and-drop message.
    $help_elements = ['help', '#help', 'help_text', '#help_text'];
    foreach ($help_elements as $help_element) {
      if (isset($form[$help_element])) {
        $form[$help_element]['#access'] = FALSE;
      }
    }
  }
}

/**
 * Submit handler for search filter.
 */
function ttd_topics_search_submit(array &$form, FormStateInterface $form_state) {
  $search = $form_state->getValue('search');
  $min_posts = $form_state->getValue('min_posts');
  $current_path = \Drupal::request()->getPathInfo();

  $query_params = [];
  if (!empty($search)) {
    $query_params['search'] = $search;
  }
  if (!empty($min_posts)) {
    $query_params['min_posts'] = $min_posts;
  }

  $url = Url::fromUserInput($current_path, ['query' => $query_params]);
  $form_state->setRedirectUrl($url);
}

/**
 * Submit handler for search reset.
 */
function ttd_topics_search_reset(array &$form, FormStateInterface $form_state) {
  $current_path = \Drupal::request()->getPathInfo();
  $url = Url::fromUserInput($current_path);
  $form_state->setRedirectUrl($url);
}

/**
 * Validates bulk hide/show actions on the TopicalBoost topic list.
 */
function ttd_topics_bulk_terms_validate(array &$form, FormStateInterface $form_state): void {
  $action = $form_state->getValue('ttd_topics_bulk_action');
  $selected_terms = array_filter((array) $form_state->getValue('ttd_topics_bulk_terms', []));

  if (!in_array($action, ['ttd_hide', 'ttd_unhide'], TRUE)) {
    $form_state->setErrorByName('ttd_topics_bulk_action', t('Choose a bulk action.'));
  }

  if (empty($selected_terms)) {
    $form_state->setErrorByName('ttd_topics_bulk_terms', t('Select at least one topic.'));
  }
}

/**
 * Applies bulk hide/show actions on the TopicalBoost topic list.
 */
function ttd_topics_bulk_terms_submit(array &$form, FormStateInterface $form_state): void {
  if (!\Drupal::currentUser()->hasPermission('administer taxonomy')) {
    \Drupal::messenger()->addError(t('You do not have permission to update topics.'));
    return;
  }

  $action = $form_state->getValue('ttd_topics_bulk_action');
  $selected_terms = array_map('intval', array_filter((array) $form_state->getValue('ttd_topics_bulk_terms', [])));
  $hide = $action === 'ttd_hide';
  $updated = 0;
  $cache_tags = ['taxonomy_term_list:ttd_topics'];

  /** @var \Drupal\taxonomy\TermStorageInterface $term_storage */
  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  foreach ($term_storage->loadMultiple($selected_terms) as $term) {
    if (!$term instanceof Term || $term->bundle() !== 'ttd_topics' || !$term->hasField('field_hide')) {
      continue;
    }

    $term->set('field_hide', $hide);
    $term->save();
    $cache_tags[] = 'taxonomy_term:' . $term->id();
    $updated++;
  }

  if ($updated > 0) {
    \Drupal::service('cache_tags.invalidator')->invalidateTags($cache_tags);
    $message = $hide
      ? \Drupal::translation()->formatPlural($updated, '1 topic hidden.', '@count topics hidden.')
      : \Drupal::translation()->formatPlural($updated, '1 topic unhidden.', '@count topics unhidden.');
    \Drupal::messenger()->addStatus($message);
  }
  else {
    \Drupal::messenger()->addWarning(t('No topics were updated.'));
  }

  $current_path = \Drupal::request()->getPathInfo();
  $query = \Drupal::request()->query->all();
  $form_state->setRedirectUrl(Url::fromUserInput($current_path, ['query' => $query]));
}

/**
 * Submit handler to save pinned posts from the taxonomy term form.
 */
function ttd_topics_pinned_posts_submit(array &$form, FormStateInterface $form_state) {
  $term = $form_state->getFormObject()->getEntity();
  if (!$term->hasField('field_pinned_posts')) {
    return;
  }

  $pinned_nids_value = $form_state->getValue('pinned_nids');
  $pinned_nids = [];
  if (!empty($pinned_nids_value)) {
    $pinned_nids = array_filter(array_map('intval', explode(',', $pinned_nids_value)));
  }

  // Limit to 3 pinned posts.
  $pinned_nids = array_slice($pinned_nids, 0, 3);

  $references = [];
  foreach ($pinned_nids as $nid) {
    $references[] = ['target_id' => $nid];
  }

  $term->set('field_pinned_posts', $references);
  $term->save();
}

/**
 * Implements hook_views_post_execute().
 *
 * Injects pinned posts at the top of taxonomy term page views for ttd_topics.
 */
function ttd_topics_views_post_execute(\Drupal\views\ViewExecutable $view) {
  // Only target the taxonomy term page view.
  if ($view->id() !== 'taxonomy_term' || $view->current_display !== 'page_1') {
    return;
  }

  // Check if we're viewing a ttd_topics term.
  $term = \Drupal::routeMatch()->getParameter('taxonomy_term');
  if (!$term || $term->bundle() !== 'ttd_topics') {
    return;
  }

  if (!$term->hasField('field_pinned_posts') || $term->get('field_pinned_posts')->isEmpty()) {
    return;
  }

  $pinned_nids = [];
  foreach ($term->get('field_pinned_posts') as $ref) {
    if ($ref->target_id) {
      $pinned_nids[] = (int) $ref->target_id;
    }
  }

  if (empty($pinned_nids)) {
    return;
  }

  // Load pinned nodes and create view result rows.
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $pinned_rows = [];
  $existing_nids = [];

  foreach ($view->result as $row) {
    if (isset($row->nid)) {
      $existing_nids[] = (int) $row->nid;
    }
  }

  foreach ($pinned_nids as $nid) {
    $node = $node_storage->load($nid);
    if (!$node || !$node->isPublished()) {
      continue;
    }

    // Create a result row for this pinned node.
    $row = new \Drupal\views\ResultRow();
    $row->_entity = $node;
    $row->nid = $node->id();
    $row->_pinned = TRUE;
    $pinned_rows[] = $row;

    // Remove from existing results if already present to avoid duplicates.
    foreach ($view->result as $key => $existing_row) {
      if (isset($existing_row->nid) && (int) $existing_row->nid === $nid) {
        unset($view->result[$key]);
        break;
      }
    }
  }

  // Prepend pinned rows.
  if (!empty($pinned_rows)) {
    $view->result = array_merge($pinned_rows, array_values($view->result));
    // Re-index.
    $view->result = array_values($view->result);
    foreach ($view->result as $index => $row) {
      $row->index = $index;
    }
  }
}

/**
 * Implements hook_preprocess_HOOK() for views-view-table.html.twig.
 */
function ttd_topics_preprocess_views_view_table(array &$variables) {
  $view = $variables['view'] ?? NULL;
  if (!$view || $view->id() !== 'content' || empty($variables['rows'])) {
    return;
  }

  if (\Drupal::config('ttd_topics.settings')->get('hide_seo_module_ui')) {
    ttd_topics_remove_admin_content_seo_columns($variables);
  }

  $variables['header']['ttd_topics'] = [
    'attributes' => new Attribute(['class' => ['views-field', 'views-field-ttd-topics']]),
    'content' => t('Topics'),
    'default_classes' => FALSE,
  ];

  foreach ($variables['rows'] as $index => &$row) {
    $node = $view->result[$index]->_entity ?? NULL;
    $cell = $node instanceof NodeInterface
      ? ttd_topics_build_admin_content_topics_cell($node)
      : '';
    $row['columns']['ttd_topics'] = [
      'attributes' => new Attribute(['class' => ['views-field', 'views-field-ttd-topics']]),
      'content' => [
        [
          'field_output' => ['#markup' => $cell],
        ],
      ],
      'default_classes' => FALSE,
      'fields' => ['ttd-topics'],
    ];
  }
}

/**
 * Removes SEO module columns from Drupal's admin content table.
 *
 * @param array $variables
 *   Views table preprocess variables.
 */
function ttd_topics_remove_admin_content_seo_columns(array &$variables): void {
  $seo_column_keys = [];

  foreach ($variables['header'] ?? [] as $key => $column) {
    $label = $column['content'] ?? '';
    if (ttd_topics_is_admin_content_seo_column($key, $label)) {
      $seo_column_keys[] = $key;
    }
  }

  if (empty($seo_column_keys)) {
    return;
  }

  foreach ($seo_column_keys as $key) {
    unset($variables['header'][$key], $variables['fields'][$key]);
    foreach ($variables['rows'] as &$row) {
      unset($row['columns'][$key]);
    }
  }
}

/**
 * Checks whether a Views table column belongs to an SEO module.
 *
 * @param string|int $key
 *   Column key.
 * @param mixed $label
 *   Renderable or scalar column label.
 *
 * @return bool
 *   TRUE when the column should be hidden.
 */
function ttd_topics_is_admin_content_seo_column($key, $label): bool {
  $key = strtolower(str_replace(['_', ' '], '-', (string) $key));
  $label = strtolower(str_replace(['_', ' '], '-', (string) $label));

  $patterns = [
    'aioseo',
    'all-in-one-seo',
    'field-meta-tags',
    'field-metatag',
    'field-yoast-seo',
    'focuskw',
    'focus-keyword',
    'metadesc',
    'meta-description',
    'meta-tags',
    'meta-title',
    'metatag',
    'rank-math',
    'readability',
    'seo-description',
    'seo-details',
    'seo-score',
    'seo-title',
    'seopress',
    'simple-sitemap',
    'sitemap',
    'wpseo',
    'xml-sitemap',
    'yoast',
  ];

  foreach ($patterns as $pattern) {
    if (strpos($key, $pattern) !== FALSE || strpos($label, $pattern) !== FALSE) {
      return TRUE;
    }
  }

  return FALSE;
}

/**
 * Builds the Topics column value for Drupal's admin content table.
 *
 * @param \Drupal\node\NodeInterface $node
 *   Content row node.
 *
 * @return \Drupal\Core\Render\Markup|string
 *   Renderable topic links or an empty marker.
 */
function ttd_topics_build_admin_content_topics_cell(NodeInterface $node) {
  if (!$node->hasField('field_ttd_topics') || $node->get('field_ttd_topics')->isEmpty()) {
    return Markup::create('<span class="ttd-admin-content-topics-empty">-</span>');
  }

  $links = [];
  foreach ($node->get('field_ttd_topics')->referencedEntities() as $term) {
    if (!$term instanceof Term) {
      continue;
    }

    $url = Url::fromRoute('entity.taxonomy_term.canonical', ['taxonomy_term' => $term->id()])->toString();
    $links[] = '<a href="' . htmlspecialchars($url, ENT_QUOTES, 'UTF-8') . '">' . htmlspecialchars($term->label(), ENT_QUOTES, 'UTF-8') . '</a>';
    if (count($links) >= 5) {
      break;
    }
  }

  $total = $node->get('field_ttd_topics')->count();
  if ($total > count($links)) {
    $links[] = t('+@count more', ['@count' => $total - count($links)]);
  }

  return Markup::create(implode(', ', $links));
}

/**
 * Implements hook_url_inbound_alter().
 * Provides custom routing for the improved overview page.
 */
function ttd_topics_url_inbound_alter(&$path, $original_path, $path_language) {
  if ($path === '/admin/config/content/ttd-topics/test-overview') {
    $path = '/ttd-topics/test-overview';
  }
}

/**
 * Custom page callback for improved topics overview.
 */
function ttd_topics_improved_overview_page() {
  $controller = new TtdTopicsController();
  return $controller->overviewPage();
}

/**
 * Implements hook_page_top().
 *
 * Simple redirect approach to handle /overview path.
 */
function ttd_topics_page_top(array &$page_top) {
  $current_path = \Drupal::service('path.current')->getPath();
  if ($current_path === '/admin/config/content/ttd-topics/overview') {
    $response = new RedirectResponse('/admin/config/content/ttd-topics?view=overview');
    $response->send();
    exit;
  }

  if (!\Drupal::service('router.admin_context')->isAdminRoute()) {
    return;
  }

  $route_name = \Drupal::routeMatch()->getRouteName();
  $notices = ttd_topics_get_admin_notices($route_name);
  if (empty($notices)) {
    return;
  }

  $page_top['ttd_topics_admin_notices'] = [
    '#type' => 'container',
    '#attributes' => ['class' => ['ttd-admin-notices']],
    '#attached' => [
      'library' => ['ttd_topics/admin_notices'],
    ],
  ];

  foreach ($notices as $index => $notice) {
    $classes = [
      'ttd-admin-notice',
      'messages',
      'messages--' . $notice['severity'],
    ];
    if (!empty($notice['dismissible'])) {
      $classes[] = 'ttd-admin-notice--dismissible';
    }

    $markup = '<div class="ttd-admin-notice__content">' . $notice['body'] . '</div>';
    if (!empty($notice['dismissible'])) {
      $markup .= '<button type="button" class="ttd-admin-notice__dismiss" data-ttd-notice-dismiss aria-label="' . t('Dismiss notice') . '">&times;</button>';
    }

    $page_top['ttd_topics_admin_notices']['notice_' . $index] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => $classes,
        'role' => $notice['severity'] === 'error' ? 'alert' : 'status',
        'data-ttd-notice-id' => $notice['id'],
      ],
      'content' => [
        '#markup' => Markup::create($markup),
      ],
    ];
  }
}

/**
 * Builds TopicalBoost admin notices matching the WordPress plugin behavior.
 *
 * @param string|null $route_name
 *   Current route name.
 *
 * @return array
 *   Notice definitions.
 */
function ttd_topics_get_admin_notices($route_name = NULL) {
  $notices = [];
  $settings_url = Url::fromRoute('topicalboost.settings_form')->toString();

  $db_error = \Drupal::state()->get('ttd_db_upgrade_failed') ?: \Drupal::state()->get('ttd_activation_error');
  if ($db_error) {
    $notices[] = [
      'id' => 'ttd-db-setup-failed',
      'severity' => 'error',
      'dismissible' => FALSE,
      'body' => '<p><strong>TopicalBoost:</strong> ' . t('Database setup failed: @error. Will retry in 5 minutes.', [
        '@error' => $db_error,
      ]) . '</p>',
    ];
  }

  $config = \Drupal::config('ttd_topics.settings');
  $api_key = trim((string) $config->get('topicalboost_api_key'));
  if ($api_key === '' || $route_name === 'topicalboost.settings_form') {
    return $notices;
  }

  if (!ttd_topics_is_current_api_key_validated($config)) {
    $notices[] = [
      'id' => 'ttd-api-key-unvalidated',
      'severity' => 'error',
      'dismissible' => TRUE,
      'body' => '<p><strong>TopicalBoost:</strong> ' . t('Your API key is invalid or could not be validated.') . ' <a href="' . htmlspecialchars($settings_url, ENT_QUOTES, 'UTF-8') . '">' . t('Check your settings') . '</a>.</p>',
    ];
    return $notices;
  }

  ttd_topics_maybe_refresh_api_status();
  $config = \Drupal::config('ttd_topics.settings');
  if (!ttd_topics_is_current_api_key_validated($config)) {
    $notices[] = [
      'id' => 'ttd-api-key-unvalidated',
      'severity' => 'error',
      'dismissible' => TRUE,
      'body' => '<p><strong>TopicalBoost:</strong> ' . t('Your API key is invalid or could not be validated.') . ' <a href="' . htmlspecialchars($settings_url, ENT_QUOTES, 'UTF-8') . '">' . t('Check your settings') . '</a>.</p>',
    ];
    return $notices;
  }

  $lines = [];
  $severity = 'warning';
  $status = strtoupper((string) ($config->get('subscription_status') ?: 'ACTIVE'));
  $allowed_statuses = ['ACTIVE', 'TRIALING', 'RETAINER'];
  if (!in_array($status, $allowed_statuses, TRUE)) {
    $subscription_messages = [
      'PAST_DUE' => t('Your payment is past due. Update your payment method to avoid service interruption.'),
      'INACTIVE' => t('Your subscription is paused. Resume your subscription to continue using the plugin.'),
      'CANCELED' => t('Your subscription has been canceled. Reactivate to continue.'),
      'UNPAID' => t('Your payment has failed. Update your payment method to restore access.'),
    ];
    $lines[] = isset($subscription_messages[$status])
      ? (string) $subscription_messages[$status]
      : t('Subscription status: @status.', ['@status' => $status]);
    if (in_array($status, ['CANCELED', 'UNPAID'], TRUE)) {
      $severity = 'error';
    }
  }

  $mismatch = $config->get('domain_mismatch');
  if (is_array($mismatch) && !empty($mismatch)) {
    $domain = trim((string) ($mismatch['registered_domain'] ?? ''));
    $environment = trim((string) ($mismatch['registered_environment'] ?? ''));
    if ($domain !== '' || $environment !== '') {
      $label = ($domain !== '' && $environment !== '') ? $domain . ' (' . $environment . ')' : ($domain ?: $environment);
      $current_domain = \Drupal::request()->getHost() ?: 'this site';
      $lines[] = 'This API key is registered for <strong>' . htmlspecialchars($label, ENT_QUOTES, 'UTF-8') . '</strong>, but this site is <strong>' . htmlspecialchars($current_domain, ENT_QUOTES, 'UTF-8') . '</strong>. Analysis will not work from this site. Use the API key for this environment or add this domain in TopicalBoost.';
    }
  }

  if (empty($lines)) {
    return $notices;
  }

  $body = '<strong>TopicalBoost:</strong> ' . ttd_topics_notice_lines_markup($lines);
  $body .= ' <a href="' . htmlspecialchars($settings_url, ENT_QUOTES, 'UTF-8') . '">' . t('Settings') . '</a>';
  $notices[] = [
    'id' => 'ttd-subscription-domain-' . substr(hash('sha256', implode('|', $lines)), 0, 12),
    'severity' => $severity,
    'dismissible' => TRUE,
    'body' => $body,
  ];

  return $notices;
}

/**
 * Checks whether the saved API key has been validated.
 *
 * @param \Drupal\Core\Config\ImmutableConfig $config
 *   TopicalBoost settings.
 *
 * @return bool
 *   TRUE if the current saved key has a successful validation record.
 */
function ttd_topics_is_current_api_key_validated($config) {
  $api_key = trim((string) $config->get('topicalboost_api_key'));
  $validated = (bool) $config->get('api_key_validated');
  $stored_hash = (string) $config->get('api_key_validation_hash');

  return $api_key !== ''
    && $validated
    && $stored_hash !== ''
    && hash_equals($stored_hash, hash('sha256', $api_key));
}

/**
 * Refreshes API validation, subscription status, and domain mismatch state.
 *
 * @param bool $force
 *   TRUE to bypass the five-minute throttle.
 */
function ttd_topics_maybe_refresh_api_status($force = FALSE) {
  $config = \Drupal::config('ttd_topics.settings');
  if (!ttd_topics_is_current_api_key_validated($config)) {
    return;
  }

  $state = \Drupal::state();
  $now = \Drupal::time()->getRequestTime();
  if (!$force && ($now - (int) $state->get('ttd_subscription_checked_at', 0)) < 5 * 60) {
    return;
  }
  $state->set('ttd_subscription_checked_at', $now);

  $api_key = trim((string) $config->get('topicalboost_api_key'));
  $api_endpoint = defined('TOPICALBOOST_API_ENDPOINT') ? TOPICALBOOST_API_ENDPOINT : 'https://api.topicalboost.com';
  $endpoint = rtrim($api_endpoint, '/') . '/validate-api-key';

  try {
    $response = \Drupal::httpClient()->post($endpoint, [
      'headers' => [
        'Content-Type' => 'application/json',
        'x-api-key' => $api_key,
      ],
      'json' => [
        'api_key' => $api_key,
        'site_url' => \Drupal::request()->getSchemeAndHttpHost(),
      ],
      'timeout' => 3,
    ]);

    if ($response->getStatusCode() === 200) {
      $data = json_decode($response->getBody()->getContents(), TRUE) ?: [];
      ttd_topics_save_api_status($api_key, $data);
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('ttd_topics')->warning('API status refresh failed: @message', [
      '@message' => $e->getMessage(),
    ]);
  }
}

/**
 * Persists API validation response state.
 *
 * @param string $api_key
 *   API key that was validated.
 * @param array $data
 *   Decoded API response.
 */
function ttd_topics_save_api_status($api_key, array $data) {
  $config = \Drupal::configFactory()->getEditable('ttd_topics.settings');
  $valid = !empty($data['valid']);

  $config
    ->set('api_key_validated', $valid)
    ->set('api_key_validation_hash', hash('sha256', $api_key));

  if (!$valid) {
    $config
      ->set('subscription_status', '')
      ->set('domain_mismatch', [])
      ->save();
    return;
  }

  if (!empty($data['subscription_status'])) {
    $config->set('subscription_status', strtoupper(trim((string) $data['subscription_status'])));
  }

  if (!empty($data['domain_mismatch'])) {
    $config->set('domain_mismatch', [
      'registered_domain' => trim((string) ($data['registered_domain'] ?? '')),
      'registered_environment' => trim((string) ($data['registered_environment'] ?? '')),
    ]);
  }
  else {
    $config->set('domain_mismatch', []);
  }

  $config->save();
}

/**
 * Converts one or more sanitized notice lines into markup.
 *
 * @param array $lines
 *   Notice lines.
 *
 * @return string
 *   Markup for rendering the lines.
 */
function ttd_topics_notice_lines_markup(array $lines) {
  if (count($lines) === 1) {
    return (string) reset($lines);
  }

  $items = '';
  foreach ($lines as $line) {
    $items .= '<li>' . $line . '</li>';
  }

  return '<ul>' . $items . '</ul>';
}

/**
 * Demand metrics cache TTL in seconds (90 days to match API and WordPress).
 */
const TTD_DEMAND_CACHE_TTL = 90 * 24 * 60 * 60; // 7,776,000 seconds

/**
 * Get demand metrics from cache.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 *
 * @return array|null
 *   Demand metrics data array or NULL if cache miss/expired.
 */
function ttd_get_demand_metrics($term_or_keyword) {
  $cache_key = ttd_get_demand_cache_key($term_or_keyword);
  $cached_data = \Drupal::state()->get($cache_key);

  if (!$cached_data) {
    return NULL;
  }

  // Check if cache is still valid
  if (isset($cached_data['fetched_at'])) {
    $fetched_time = strtotime($cached_data['fetched_at']);
    $expiry_time = $fetched_time + TTD_DEMAND_CACHE_TTL;

    if (time() >= $expiry_time) {
      // Cache expired - delete and return null
      \Drupal::state()->delete($cache_key);
      return NULL;
    }
  }

  return $cached_data;
}

/**
 * Store demand metrics in cache.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 * @param array $metrics_data
 *   Demand metrics data to store (keyword_difficulty, search_volume).
 *
 * @return bool
 *   TRUE on success.
 */
function ttd_store_demand_metrics($term_or_keyword, array $metrics_data) {
  $cache_key = ttd_get_demand_cache_key($term_or_keyword);

  // Add timestamp to the data
  $cache_data = array_merge($metrics_data, [
    'fetched_at' => gmdate('c'),
  ]);

  \Drupal::state()->set($cache_key, $cache_data);
  return TRUE;
}

/**
 * Generate cache key for demand metrics.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 *
 * @return string
 *   Cache key string.
 */
function ttd_get_demand_cache_key($term_or_keyword) {
  if (is_numeric($term_or_keyword)) {
    // Entity topic (by term_id)
    return 'ttd_demand_metrics_entity_' . intval($term_or_keyword);
  }
  else {
    // Manual topic (by keyword)
    return 'ttd_demand_metrics_keyword_' . md5($term_or_keyword);
  }
}

/**
 * Get salience category for a term on a specific node.
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string|null
 *   The salience category ('about' or 'mentions') or NULL if not found.
 */
function ttd_get_term_salience_category($term_id, $node_id) {
  return ttd_get_topic_tier($term_id, $node_id);
}

/**
 * Compute WordPress-compatible salience tiers.
 *
 * Matches TTd\Topics\Entity_DB::compute_tiers():
 * - LLM tiers are authoritative when any entity has one.
 * - Salience-only fallback uses 10% for mainEntity and 5% for about.
 * - Only one mainEntity and at most four about topics are allowed.
 * - User overrides win before natural tier assignment.
 *
 * @param array $entities
 *   Rows with entity_id, salience_score, and optional llm_tier.
 * @param array $overrides
 *   Map of entity ID to forced tier.
 *
 * @return array
 *   Map of entity ID to mainEntity/about/mentions.
 */
function ttd_topics_compute_tiers(array $entities, array $overrides = []): array {
  $main_entity_min = 0.10;
  $about_min = 0.05;
  $max_about = 4;

  $main_entity_assigned = FALSE;
  $about_count = 0;
  $tiers = [];
  $has_llm_tiers = FALSE;

  foreach ($entities as $entity) {
    if (!empty($entity['llm_tier'])) {
      $has_llm_tiers = TRUE;
      break;
    }
  }

  foreach ($entities as $entity) {
    $entity_id = (int) ($entity['entity_id'] ?? 0);
    if (!$entity_id || !isset($overrides[$entity_id])) {
      continue;
    }

    $tier = $overrides[$entity_id];
    $tiers[$entity_id] = $tier;
    if ($tier === 'mainEntity') {
      $main_entity_assigned = TRUE;
    }
    elseif ($tier === 'about') {
      $about_count++;
    }
  }

  if ($has_llm_tiers) {
    foreach ($entities as $entity) {
      $entity_id = (int) ($entity['entity_id'] ?? 0);
      if (!$entity_id || isset($tiers[$entity_id])) {
        continue;
      }

      $llm_tier = $entity['llm_tier'] ?? NULL;
      if ($llm_tier === 'mainEntity') {
        if (!$main_entity_assigned) {
          $tiers[$entity_id] = 'mainEntity';
          $main_entity_assigned = TRUE;
        }
        elseif ($about_count < $max_about) {
          $tiers[$entity_id] = 'about';
          $about_count++;
        }
        else {
          $tiers[$entity_id] = 'mentions';
        }
      }
      elseif ($llm_tier === 'about') {
        if ($about_count < $max_about) {
          $tiers[$entity_id] = 'about';
          $about_count++;
        }
        else {
          $tiers[$entity_id] = 'mentions';
        }
      }
      elseif ($llm_tier) {
        $tiers[$entity_id] = $llm_tier;
      }
      else {
        $tiers[$entity_id] = 'mentions';
      }
    }

    return $tiers;
  }

  usort($entities, static function ($a, $b) {
    $score_a = $a['salience_score'] ?? -1;
    $score_b = $b['salience_score'] ?? -1;
    return $score_b <=> $score_a;
  });

  foreach ($entities as $entity) {
    $entity_id = (int) ($entity['entity_id'] ?? 0);
    if (!$entity_id || isset($tiers[$entity_id])) {
      continue;
    }

    $score = $entity['salience_score'] ?? 0;
    if (!$main_entity_assigned && $score >= $main_entity_min) {
      $tiers[$entity_id] = 'mainEntity';
      $main_entity_assigned = TRUE;
    }
    elseif ($about_count < $max_about && $score >= $about_min) {
      $tiers[$entity_id] = 'about';
      $about_count++;
    }
    else {
      $tiers[$entity_id] = 'mentions';
    }
  }

  return $tiers;
}

/**
 * Remove stale tier overrides when fresh LLM tier data is available.
 *
 * This matches the WordPress re-analysis behavior: explicit user overrides
 * should not keep winning over fresh hybrid-extraction tiers for the same
 * entity, but NLP/salience-only analyses should preserve existing overrides.
 *
 * @param array $overrides
 *   Map of entity ID to overridden tier.
 * @param array $salience_map
 *   Map of entity ID to salience data, optionally including llm_tier.
 *
 * @return array
 *   Override map with stale LLM-backed overrides removed.
 */
function ttd_topics_clear_stale_tier_overrides(array $overrides, array $salience_map): array {
  $has_llm_tiers = FALSE;
  foreach ($salience_map as $data) {
    if (!empty($data['llm_tier'])) {
      $has_llm_tiers = TRUE;
      break;
    }
  }

  if (!$has_llm_tiers || empty($overrides)) {
    return $overrides;
  }

  foreach ($overrides as $entity_id => $tier) {
    $numeric_entity_id = (int) $entity_id;
    if (isset($salience_map[$numeric_entity_id]) && !empty($salience_map[$numeric_entity_id]['llm_tier'])) {
      unset($overrides[$entity_id]);
    }
  }

  return $overrides;
}

/**
 * Get salience data for all entities on a node.
 *
 * Returns array indexed by ttd_id with salience_score and salience_category.
 * Used by frontend display to order topics by relevance.
 *
 * @param int $node_id
 *   The node ID.
 *
 * @return array
 *   Array of [ttd_id => ['salience_score' => float|null, 'salience_category' => string|null]].
 */
function ttd_get_node_salience_data($node_id) {
  $database = \Drupal::database();
  $results = $database->select('ttd_entity_post_ids', 'ep')
    ->fields('ep', ['entity_id', 'salience_score', 'salience_category'])
    ->condition('post_id', $node_id)
    ->execute()
    ->fetchAll();

  $overrides = [];
  $node = \Drupal::entityTypeManager()->getStorage('node')->load($node_id);
  if ($node && $node->hasField('field_tier_overrides')) {
    $override_values = $node->get('field_tier_overrides')->value ?? [];
    if (is_array($override_values)) {
      foreach ($override_values as $key => $tier) {
        if (is_numeric($key)) {
          $overrides[(int) $key] = $tier;
        }
      }
    }
  }

  $entities = [];
  $entity_ids_in_results = [];
  foreach ($results as $row) {
    $entity_id = (int) $row->entity_id;
    $entities[] = [
      'entity_id' => $entity_id,
      'salience_score' => $row->salience_score !== NULL ? (float) $row->salience_score : NULL,
      'llm_tier' => $row->salience_category ?: NULL,
    ];
    $entity_ids_in_results[$entity_id] = TRUE;
  }

  foreach ($overrides as $entity_id => $tier) {
    if (!isset($entity_ids_in_results[$entity_id])) {
      $entities[] = [
        'entity_id' => $entity_id,
        'salience_score' => NULL,
        'llm_tier' => NULL,
      ];
    }
  }

  $computed_tiers = ttd_topics_compute_tiers($entities, $overrides);

  $salience_map = [];
  foreach ($results as $row) {
    $entity_id = (int) $row->entity_id;
    $salience_map[(int) $row->entity_id] = [
      'salience_score' => $row->salience_score !== NULL ? (float) $row->salience_score : NULL,
      'salience_category' => $computed_tiers[$entity_id] ?? ($row->salience_category ?: 'mentions'),
    ];
  }

  foreach ($overrides as $entity_id => $tier) {
    if (!isset($salience_map[$entity_id])) {
      $salience_map[$entity_id] = [
        'salience_score' => NULL,
        'salience_category' => $computed_tiers[$entity_id] ?? $tier,
      ];
    }
  }

  return $salience_map;
}

/**
 * Get KD difficulty color based on value.
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   Hex color code.
 */
function ttd_get_kd_color($difficulty) {
  if ($difficulty >= 90) {
    return '#dc2626';
  }
  if ($difficulty >= 70) {
    return '#ea580c';
  }
  if ($difficulty >= 50) {
    return '#ca8a04';
  }
  if ($difficulty >= 30) {
    return '#65a30d';
  }
  return '#16a34a';
}

/**
 * Get difficulty label for a KD value.
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   Human-readable difficulty label.
 */
function ttd_get_kd_label($difficulty) {
  if ($difficulty <= 30) {
    return 'Easy';
  }
  if ($difficulty <= 60) {
    return 'Medium';
  }
  if ($difficulty <= 80) {
    return 'Hard';
  }
  return 'Very Hard';
}

/**
 * Format volume with K/M notation.
 *
 * @param int $volume
 *   Search volume value.
 *
 * @return string
 *   Formatted volume string.
 */
function ttd_format_volume($volume) {
  if (!$volume && $volume !== 0) {
    return '--';
  }
  $num = (int) $volume;
  if ($num >= 1000000) {
    return round($num / 1000000, 1) . 'M';
  }
  if ($num >= 1000) {
    return round($num / 1000, 1) . 'K';
  }
  return (string) $num;
}

/**
 * Get KD badge markup for a term (About topics only).
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   HTML markup for the KD badge, or empty string if not applicable.
 */
function ttd_get_kd_badge($term_id, $node_id) {
  // Check if this is an About topic.
  $salience = ttd_get_term_salience_category($term_id, $node_id);
  if ($salience !== 'about') {
    return '';
  }

  // Get cached demand metrics.
  $metrics = ttd_get_demand_metrics($term_id);
  if (!$metrics || !isset($metrics['keyword_difficulty'])) {
    return '';
  }

  $kd = (int) $metrics['keyword_difficulty'];
  $sv = isset($metrics['search_volume']) ? (int) $metrics['search_volume'] : 0;
  $color = ttd_get_kd_color($kd);
  $label = ttd_get_kd_label($kd);
  $sv_formatted = ttd_format_volume($sv);

  $tooltip = t('Monthly search volume: @volume | Difficulty: @kd/100 (@label)', [
    '@volume' => $sv_formatted,
    '@kd' => $kd,
    '@label' => $label,
  ]);

  return '<span class="ttd-kd-badge" style="color: ' . $color . ';" title="' . $tooltip . '">' . $sv_formatted . '</span>';
}

/**
 * Ensure the ttd_topics Pathauto pattern exists.
 *
 * This helper is used during install and whenever Pathauto is installed
 * afterwards, guaranteeing that topic terms always receive friendly aliases.
 */
function ttd_topics_ensure_pathauto_pattern() {
  /** @var \Drupal\Core\Entity\EntityStorageInterface $pattern_storage */
  $pattern_storage = \Drupal::entityTypeManager()->getStorage('pathauto_pattern');

  // Bail if the pattern already exists.
  if ($pattern_storage->load('ttd_topics')) {
    return;
  }

  // Determine the desired prefix from configuration, defaulting to /topics/.
  $config = \Drupal::configFactory()->getEditable('ttd_topics.settings');
  $prefix = $config->get('topic_url_path_prefix') ?: '/topics/';
  $prefix = '/' . trim($prefix, '/') . '/';

  $pattern = $prefix . '[term:name]';

  // Create the pattern entity.
  $pattern_storage->create([
    'id' => 'ttd_topics',
    'label' => 'TTD Topics',
    'type' => 'canonical_entities:taxonomy_term',
    'pattern' => $pattern,
    'selection_criteria' => [
      [
        'id' => 'entity_bundle:taxonomy_term',
        'bundles' => ['ttd_topics' => 'ttd_topics'],
        'negate' => FALSE,
        'context_mapping' => ['taxonomy_term' => 'taxonomy_term'],
      ],
    ],
    'weight' => 0,
    'status' => TRUE,
  ])->save();

  // Clear caches so the new pattern is recognised immediately.
  \Drupal::service('plugin.manager.alias_type')->clearCachedDefinitions();
  \Drupal::messenger()->addMessage(t('Pathauto pattern for TTD Topics was created automatically.'));
}

/**
 * Implements hook_modules_installed().
 *
 * Creates the Pathauto pattern if Pathauto is enabled after TopicalBoost.
 */
function ttd_topics_modules_installed($modules) {
  if (in_array('pathauto', $modules, TRUE)) {
    ttd_topics_ensure_pathauto_pattern();
  }
}

/**
 * Get the effective tier for a topic on a node (WP beta features).
 *
 * Priority: tier_overrides > salience_category > default ('mentions').
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   The tier: 'mainEntity', 'about', 'mentions', or 'below-threshold'.
 */
function ttd_get_topic_tier($term_id, $node_id) {
  $node = \Drupal::entityTypeManager()->getStorage('node')->load($node_id);
  if (!$node) {
    return 'mentions';
  }

  // Get term's ttd_id
  $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($term_id);
  if (!$term || !$term->hasField('field_ttd_id')) {
    return 'mentions';
  }
  $ttd_id = $term->get('field_ttd_id')->value;

  // Check tier_overrides first (highest priority)
  $tier_overrides = $node->hasField('field_tier_overrides')
    ? ($node->get('field_tier_overrides')->value ?? [])
    : [];
  if (is_array($tier_overrides)) {
    // Check by ttd_id
    if ($ttd_id && isset($tier_overrides[(string) $ttd_id])) {
      return $tier_overrides[(string) $ttd_id];
    }
    // Check by term_id
    $term_key = 'term_' . $term_id;
    if (isset($tier_overrides[$term_key])) {
      return $tier_overrides[$term_key];
    }
  }

  // Fall back to computed salience data from database.
  if ($ttd_id) {
    $salience_data = ttd_get_node_salience_data($node_id);
    if (!empty($salience_data[(int) $ttd_id]['salience_category'])) {
      return $salience_data[(int) $ttd_id]['salience_category'];
    }
  }

  // Default to 'mentions'
  return 'mentions';
}

/**
 * Format count with K/M notation (WP beta features).
 *
 * @param int $count
 *   The count value.
 *
 * @return string
 *   Formatted count string.
 */
function ttd_format_count($count) {
  if (!$count && $count !== 0) {
    return '--';
  }
  $num = (int) $count;
  if ($num >= 1000000) {
    $val = $num / 1000000;
    return rtrim(rtrim(number_format($val, 1), '0'), '.') . 'M';
  }
  if ($num >= 1000) {
    $val = $num / 1000;
    return rtrim(rtrim(number_format($val, 1), '0'), '.') . 'K';
  }
  return (string) $num;
}

/**
 * Get CSS class for keyword difficulty (WP beta features).
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   CSS class name.
 */
function ttd_get_kd_class($difficulty) {
  if ($difficulty <= 30) {
    return 'ttd-kd-easy';
  }
  if ($difficulty <= 60) {
    return 'ttd-kd-medium';
  }
  if ($difficulty <= 80) {
    return 'ttd-kd-hard';
  }
  return 'ttd-kd-very-hard';
}

/**
 * Render KD badge for focus topics (WP beta features).
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   HTML markup for the KD badge, or empty string.
 */
function ttd_render_kd_badge($term_id, $node_id) {
  $tier = ttd_get_topic_tier($term_id, $node_id);

  // Only show badges for mainEntity and about tiers
  if (!in_array($tier, ['mainEntity', 'about'])) {
    return '';
  }

  // Get cached demand metrics
  $metrics = ttd_get_demand_metrics($term_id);
  if (!$metrics || !isset($metrics['keyword_difficulty'], $metrics['traffic_potential'])) {
    return '<span class="ttd-kd-badge ttd-kd-no-data" title="Click to fetch demand data">--</span>';
  }

  $kd = (int) $metrics['keyword_difficulty'];
  $tp = (int) $metrics['traffic_potential'];
  $kd_class = ttd_get_kd_class($kd);
  $label = ttd_get_kd_label($kd);
  $tp_formatted = ttd_format_count($tp);

  $tooltip = t('Traffic Potential: @tp | Difficulty: @kd/100 (@label) | Click to refresh', [
    '@tp' => $tp_formatted,
    '@kd' => $kd,
    '@label' => $label,
  ]);

  return '<span class="ttd-kd-badge ' . $kd_class . '" title="' . $tooltip . '" data-term-id="' . $term_id . '">' . $tp_formatted . '</span>';
}
