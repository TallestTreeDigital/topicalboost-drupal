// Load local configuration if it exists (for local development overrides)
$local_config = dirname(__FILE__) . '/local-config.php';
if (file_exists($local_config) && filesize($local_config) > 0) {
  require_once $local_config;
}

// Define the API endpoint as a constant (only if not already defined by local-config.php)
if (!defined('TOPICALBOOST_API_ENDPOINT')) {
  $use_beta_api = FALSE;
  try {
    $use_beta_api = (bool) \Drupal::config('ttd_topics.settings')->get('use_beta_api');
  }
  catch (\Throwable $e) {
    $use_beta_api = FALSE;
  }
  define('TOPICALBOOST_API_ENDPOINT', $use_beta_api ? 'https://beta.api.topicalboost.com' : 'https://api.topicalboost.com');
}

