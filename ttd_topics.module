/**
 * Runs the analysis on the node.
 */
function ttd_topics_run_analysis(NodeInterface $node) {
  // Get the queue service.
  $queue = \Drupal::queue('ttd_topics_analysis');

  // Add the node to the queue.
  $queue->createItem($node);
}

/**
 * Implements hook_form_FORM_ID_alter().
 */
function ttd_topics_form_taxonomy_term_ttd_topics_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  $term = $form_state->getFormObject()->getEntity();

  // Hide the field_ttd_id field from the form (it's used internally to connect with custom table).
  if (isset($form['field_ttd_id'])) {
    $form['field_ttd_id']['#access'] = FALSE;
  }

  // Check if the field_hide exists and is a boolean field.
  if ($term->hasField('field_hide') && $term->get('field_hide')->getFieldDefinition()->getType() == 'boolean') {
    // The field should already be present in the form, we just need to adjust its properties.
    if (isset($form['field_hide'])) {
      $form['field_hide']['widget']['value']['#title'] = t('Hide this topic');
      $form['field_hide']['widget']['value']['#description'] = t('If checked, this topic will be hidden from display.');
      // Move it to the top of the form.
      $form['field_hide']['#weight'] = -5;
    }
  }

  // Display TTD entity information if the term has a ttd_id.
  if ($term->hasField('field_ttd_id') && !$term->get('field_ttd_id')->isEmpty()) {
    $ttd_id = $term->get('field_ttd_id')->value;
    $entity_info = ttd_topics_get_ttd_entity_info($ttd_id);

    if ($entity_info) {
      $form['ttd_entity_info'] = [
        '#type' => 'details',
        '#title' => t('TopicalBoost Entity Information'),
        '#weight' => 10,
        '#open' => TRUE,
      ];

      // Display the TTD ID at the top.
      $form['ttd_entity_info']['ttd_id_display'] = [
        '#markup' => '<p><strong>' . t('TTD ID: @ttd_id', ['@ttd_id' => $ttd_id]) . '</strong></p>',
        '#weight' => -10,
      ];

      $rows = ttd_topics_format_entity_info_for_display($entity_info);

      if (!empty($rows)) {
        $form['ttd_entity_info']['entity_table'] = [
          '#type' => 'table',
          '#header' => [t('Field'), t('Value')],
          '#rows' => $rows,
          '#empty' => t('No TTD entity data available.'),
        ];
      }
      else {
        $form['ttd_entity_info']['no_data'] = [
          '#markup' => '<p>' . t('No TTD entity data available for TTD ID: @ttd_id', ['@ttd_id' => $ttd_id]) . '</p>',
        ];
      }
    }
    else {
      $form['ttd_entity_info'] = [
        '#type' => 'details',
        '#title' => t('TopicalBoost Entity Information'),
        '#weight' => 10,
        '#open' => TRUE,
      ];

      $form['ttd_entity_info']['no_entity'] = [
        '#markup' => '<p>' . t('No TTD entity found for TTD ID: @ttd_id', ['@ttd_id' => $ttd_id]) . '</p>',
      ];
    }
  }

  // Add Pinned Posts picker.
  if ($term->hasField('field_pinned_posts')) {
    $pinned_values = [];
    if (!$term->get('field_pinned_posts')->isEmpty()) {
      foreach ($term->get('field_pinned_posts') as $ref) {
        $node = $ref->entity;
        if ($node) {
          $pinned_values[] = [
            'nid' => $node->id(),
            'title' => $node->getTitle(),
          ];
        }
      }
    }

    // Hide default widget, we'll use custom JS-based picker.
    if (isset($form['field_pinned_posts'])) {
      $form['field_pinned_posts']['#access'] = FALSE;
    }

    $form['pinned_posts_section'] = [
      '#type' => 'details',
      '#title' => t('Pinned Posts'),
      '#description' => t('Pin up to 3 posts to appear at the top of this topic page.'),
      '#weight' => 15,
      '#open' => TRUE,
    ];

    $form['pinned_posts_section']['pinned_posts_widget'] = [
      '#type' => 'container',
      '#attributes' => [
        'id' => 'ttd-pinned-posts-widget',
        'data-term-id' => $term->id() ?: 0,
        'data-pinned' => json_encode($pinned_values),
      ],
    ];

    $form['pinned_posts_section']['pinned_posts_widget']['search'] = [
      '#type' => 'textfield',
      '#title' => t('Search posts'),
      '#title_display' => 'invisible',
      '#attributes' => [
        'placeholder' => t('Search for posts to pin...'),
        'id' => 'ttd-pinned-posts-search',
        'autocomplete' => 'off',
      ],
    ];

    $form['pinned_posts_section']['pinned_posts_widget']['results'] = [
      '#markup' => '<div id="ttd-pinned-posts-results"></div>',
    ];

    $form['pinned_posts_section']['pinned_posts_widget']['pinned_list'] = [
      '#markup' => '<div id="ttd-pinned-posts-list"><h4>' . t('Currently Pinned') . '</h4><ul class="ttd-pinned-list"></ul></div>',
    ];

    // Hidden field to store the actual nid values for form submission.
    $form['pinned_posts_section']['pinned_nids'] = [
      '#type' => 'hidden',
      '#default_value' => implode(',', array_column($pinned_values, 'nid')),
      '#attributes' => ['id' => 'ttd-pinned-nids'],
    ];

    $form['#attached']['library'][] = 'ttd_topics/pinned_posts';
    $form['#attached']['drupalSettings']['ttdPinnedPosts'] = [
      'termId' => $term->id() ?: 0,
      'pinned' => $pinned_values,
      'searchUrl' => '/api/topicalboost/pinned-posts/search',
      'maxPinned' => 3,
    ];

    // Add custom submit handler to save pinned posts.
    $form['actions']['submit']['#submit'][] = 'ttd_topics_pinned_posts_submit';
  }

  // Remove any custom submit handlers we might have added before.
  if (isset($form['actions']['submit']['#submit'])) {
    $form['actions']['submit']['#submit'] = array_filter($form['actions']['submit']['#submit'], function ($handler) {
      return $handler !== 'topicalboost_term_form_submit';
    });
  }
}

/**
 * Implements hook_entity_presave().
 */
function ttd_topics_entity_presave(EntityInterface $entity) {
  if ($entity instanceof NodeInterface) {
    $config = \Drupal::config('ttd_topics.settings');
    $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
    
    if (in_array($entity->bundle(), $enabled_content_types)) {
    $is_newly_published = $entity->isPublished() && (!$entity->original || !$entity->original->isPublished());

    if ($is_newly_published) {
      try {
        $queue_storage = \Drupal::entityTypeManager()->getStorage('advancedqueue_queue');
        $queue = $queue_storage->load('ttd_topics_analysis');
        if ($queue) {
          $job = Job::create('ttd_topics_analysis', [
            'node_id' => $entity->id() ? $entity->id() : $entity->uuid(),
            'force_analysis' => FALSE,
          ]);
          $queue->enqueueJob($job);

          // Set analysis in progress.
          $entity->set('field_ttd_analysis_in_progress', TRUE);

          // Block until analyzed: hold the node as unpublished until analysis completes.
          if ($config->get('block_until_analyzed')) {
            $entity->setUnpublished();
            \Drupal::messenger()->addWarning(t('This content is being held for TopicalBoost analysis and will be published automatically when complete.'));
          }
        }
        else {
          \Drupal::logger('topicalboost')->error('TopicalBoost analysis queue not found');
        }
      }
      catch (\Exception $e) {
        \Drupal::logger('topicalboost')->error('Error queueing TopicalBoost analysis job: @message', ['@message' => $e->getMessage()]);
      }
      }
    }
  }
}

/**
 * Implements hook_entity_update().
 *
 * When a node transitions to published, update the stored URL in TopicalBoost
 * so draft URLs (e.g. /node/123) are replaced with the published path alias.
 */
function ttd_topics_entity_update(EntityInterface $entity) {
  if (!($entity instanceof NodeInterface)) {
    return;
  }

  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  if (!in_array($entity->bundle(), $enabled_content_types)) {
    return;
  }

  $is_newly_published = $entity->isPublished() && $entity->original && !$entity->original->isPublished();

  if ($is_newly_published) {
    /** @var \Drupal\ttd_topics\Service\TtdTopicsAnalysisService $analysis_service */
    $analysis_service = \Drupal::service('ttd_topics.analysis_service');
    $analysis_service->updateContentUrl($entity);
  }
}

/**
 * Implements hook_entity_insert() for taxonomy terms.
 *
 * When a new ttd_topics term is created and re-analysis is enabled,
 * queue recent published nodes for re-analysis.
 */
function ttd_topics_taxonomy_term_insert(\Drupal\taxonomy\TermInterface $term) {
  if ($term->bundle() !== 'ttd_topics') {
    return;
  }

  $config = \Drupal::config('ttd_topics.settings');
  if (!$config->get('new_topic_reanalysis_enabled')) {
    return;
  }

  $lookback_days = $config->get('new_topic_reanalysis_lookback_days') ?: 30;
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  if (empty($enabled_content_types)) {
    return;
  }

  $cutoff = \Drupal::time()->getRequestTime() - ($lookback_days * 86400);

  // Find published nodes from the lookback period.
  $query = \Drupal::entityQuery('node')
    ->condition('status', 1)
    ->condition('type', $enabled_content_types, 'IN')
    ->condition('created', $cutoff, '>=')
    ->accessCheck(FALSE);

  $nids = $query->execute();

  if (empty($nids)) {
    return;
  }

  // Queue them for re-analysis via AdvancedQueue.
  try {
    $queue_storage = \Drupal::entityTypeManager()->getStorage('advancedqueue_queue');
    $queue = $queue_storage->load('ttd_topics_analysis');
    if ($queue) {
      $count = 0;
      foreach ($nids as $nid) {
        $job = Job::create('ttd_topics_analysis', [
          'node_id' => $nid,
          'force_analysis' => TRUE,
        ]);
        $queue->enqueueJob($job);
        $count++;
      }
      \Drupal::logger('topicalboost')->info('New topic "@term" created. Queued @count nodes for re-analysis.', [
        '@term' => $term->label(),
        '@count' => $count,
      ]);
    }
  }
  catch (\Exception $e) {
    \Drupal::logger('topicalboost')->error('Error queueing re-analysis for new topic: @message', ['@message' => $e->getMessage()]);
  }
}

/**
 * Implements hook_cron().
 */
function ttd_topics_cron() {
  // AdvancedQueue handles its own processing via JobType plugins with cron annotations.
  // The ttd_topics_analysis JobType should have cron settings to be processed automatically.
  // Bulk analysis is now handled by the TtdBulkAnalysisPoller job type
  // which automatically polls and triggers apply when analysis completes.

  // Flush error telemetry buffer.
  try {
    $telemetry = \Drupal::service('ttd_topics.error_telemetry');
    $telemetry->flush();
  }
  catch (\Exception $e) {
    // Silently fail.
  }

  // Check for nodes stuck in "block until analyzed" state > 15 minutes.
  $config = \Drupal::config('ttd_topics.settings');
  if ($config->get('block_until_analyzed')) {
    $cutoff = \Drupal::time()->getRequestTime() - (15 * 60);
    $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

    if (!empty($enabled_content_types)) {
      $database = \Drupal::database();
      // Find nodes with analysis_in_progress that were created > 15 min ago.
      $query = $database->select('node_field_data', 'n');
      $query->join('node__field_ttd_analysis_in_progress', 'aip', 'n.nid = aip.entity_id');
      $query->fields('n', ['nid']);
      $query->condition('aip.field_ttd_analysis_in_progress_value', 1);
      $query->condition('n.status', 0);
      $query->condition('n.type', $enabled_content_types, 'IN');
      $query->condition('n.changed', $cutoff, '<');
      $stuck_nids = $query->execute()->fetchCol();

      if (!empty($stuck_nids)) {
        $node_storage = \Drupal::entityTypeManager()->getStorage('node');
        foreach ($stuck_nids as $nid) {
          $node = $node_storage->load($nid);
          if ($node) {
            $node->setPublished();
            $node->set('field_ttd_analysis_in_progress', FALSE);
            $node->save();
            \Drupal::logger('topicalboost')->warning('Auto-published node @nid after 15-minute analysis timeout.', ['@nid' => $nid]);
          }
        }
      }
    }
  }
}

/**
 * Perform single analysis for a node.
 */
function ttd_topics_perform_single_analysis(NodeInterface $node) {
  $config = \Drupal::config('ttd_topics.settings');
  $api_key = $config->get('topicalboost_api_key');
  $api_base_url = TOPICALBOOST_API_ENDPOINT;

  $client = \Drupal::httpClient();

  try {
    // Get analysis content using field collector
    $field_collector = \Drupal::service('ttd_topics.field_collector');
    $analysis_text = $field_collector->collect($node);

    // Step 1: Initiate analysis.
    $response = $client->post($api_base_url . '/analyze/single', [
      'headers' => [
        'Content-Type' => 'application/json',
        'x-api-key' => $api_key,
      ],
      'json' => [
        'customer_id' => $node->id(),
        'url' => $node->toUrl()->setAbsolute()->toString(),
        'title' => $node->getTitle(),
        'text' => $analysis_text,
      ],
    ]);

    $result = json_decode($response->getBody(), TRUE);
    $analysis_id = $result['analysis_id'];

    // Step 2: Poll for analysis completion.
    $completed = FALSE;
    $max_attempts = 10;
    $attempt = 0;

    while (!$completed && $attempt < $max_attempts) {
      // Wait for 5 seconds between polls.
      sleep(5);
      $poll_response = $client->get($api_base_url . '/analyze/single/progress/' . $analysis_id, [
        'headers' => ['x-api-key' => $api_key],
      ]);

      $poll_result = json_decode($poll_response->getBody(), TRUE);
      if ($poll_result['status'] === 'completed') {
        $completed = TRUE;
      }

      $attempt++;
    }

    if (!$completed) {
      throw new \Exception('Analysis timed out');
    }

    // Step 3: Get analysis results.
    $results_response = $client->get($api_base_url . '/analyze/single/results/' . $analysis_id, [
      'headers' => ['x-api-key' => $api_key],
    ]);

    $analysis_results = json_decode($results_response->getBody(), TRUE);

    // Process and save the results.
    ttd_topics_save_analysis_results($node, $analysis_results);

    // Update the ttd_last_analyzed field.
    $node->set('field_ttd_last_analyzed', \Drupal::time()->getRequestTime());
    $node->save();

  }
  catch (RequestException $e) {
    \Drupal::logger('topicalboost')->error('Error during TopicalBoost analysis: @error', ['@error' => $e->getMessage()]);
  }
}

/**
 * Save the analysis results to the node.
 */
function ttd_topics_save_analysis_results(NodeInterface $node, array $results) {
  // Process the results and save them to the node
  // This is where you'd update the node's TopicalBoost field, etc.
  // Example:
  $topicalboost = [];
  foreach ($results['entities'] as $entity) {
    $topicalboost[] = [
      'target_id' => ttd_topics_get_or_create_term($entity['name'], $entity['id']),
    ];
  }
  $node->set('field_ttd_topics', $topicalboost);
  $node->save();
}

/**
 * Get or create a taxonomy term for a TTD Topic.
 */
function ttd_topics_get_or_create_term($name, $ttd_id) {
  $terms = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_term')
    ->loadByProperties([
      'vid' => 'topicalboost',
      'field_ttd_id' => $ttd_id,
    ]);

  if (!empty($terms)) {
    return reset($terms)->id();
  }

  $term = Term::create([
    'vid' => 'topicalboost',
    'name' => $name,
    'field_ttd_id' => $ttd_id,
  ]);
  $term->save();

  return $term->id();
}

/**
 * Fetches TTD entity information from the database.
 */
function ttd_topics_get_ttd_entity_info($ttd_id) {
  $connection = Database::getConnection();

  // Fetch main entity data.
  $query = $connection->select('ttd_entities', 'e')
    ->fields('e')
    ->condition('e.ttd_id', $ttd_id);
  $entity = $query->execute()->fetchAssoc();

  if (!$entity) {
    return NULL;
  }

  // Fetch schema types.
  $query = $connection->select('ttd_entity_schema_types', 'est')
    ->fields('est', ['schema_type_id'])
    ->condition('est.entity_id', $ttd_id);
  $schema_type_ids = $query->execute()->fetchCol();

  if (!empty($schema_type_ids)) {
    $query = $connection->select('ttd_schema_types', 'st')
      ->fields('st', ['name'])
      ->condition('st.ttd_id', $schema_type_ids, 'IN');
    $entity['schema_types'] = $query->execute()->fetchCol();
  }

  // Fetch WB categories.
  $query = $connection->select('ttd_entity_wb_categories', 'ewc')
    ->fields('ewc', ['wb_category_id'])
    ->condition('ewc.entity_id', $ttd_id);
  $wb_category_ids = $query->execute()->fetchCol();

  if (!empty($wb_category_ids)) {
    $query = $connection->select('ttd_wb_categories', 'wc')
      ->fields('wc', ['name'])
      ->condition('wc.id', $wb_category_ids, 'IN');
    $entity['wb_categories'] = $query->execute()->fetchCol();
  }

  return $entity;
}

/**
 * Formats entity information for display in a table.
 */
function ttd_topics_format_entity_info_for_display($entity_info) {
  $rows = [];
  $skip_fields = ['ttd_id', 'createdAt', 'updatedAt', 'count', 'hide'];

  foreach ($entity_info as $key => $value) {
    if (in_array($key, $skip_fields)) {
      continue;
    }

    // Skip empty or null values.
    if (empty($value) && $value !== '0') {
      continue;
    }

    if ($key === 'schema_types' || $key === 'wb_categories') {
      $value = is_array($value) ? implode(', ', $value) : $value;
    }
    elseif ($key === 'wb_instances') {
      $value = json_encode(json_decode($value), JSON_PRETTY_PRINT);
    }

    $rows[] = [
      'field' => ucwords(str_replace('_', ' ', $key)),
      'value' => [
        'data' => [
          '#type' => 'markup',
          '#markup' => '<pre>' . htmlspecialchars($value) . '</pre>',
        ],
      ],
    ];
  }

  return $rows;
}

/**
 * Implements hook_entity_access().
 */
function ttd_topics_entity_access(EntityInterface $entity, $operation, AccountInterface $account) {
  if ($entity->getEntityTypeId() === 'taxonomy_term' && $entity->bundle() === 'topicalboost') {
    if ($operation === 'view' && $entity->hasField('field_hide')) {
      // Get minimum display count from config.
      $config = \Drupal::config('ttd_topics.settings');
      $min_display_count = $config->get('post_topic_minimum_display_count');

      // Get post count for this term.
      $count = \Drupal::database()->select('taxonomy_index', 'ti')
        ->condition('tid', $entity->id())
        ->countQuery()
        ->execute()
        ->fetchField();

      // Return 404 if hidden OR below minimum count for anonymous users.
      if (($entity->get('field_hide')->value || $count < $min_display_count) && $account->isAnonymous()) {
        return AccessResult::forbidden()->addCacheableDependency($entity);
      }
    }
  }
  return AccessResult::neutral();
}

/**
 * AJAX callback for the "Run Analysis" button.
 */
function ttd_topics_run_analysis_ajax_callback(array &$form, FormStateInterface $form_state) {
  $node = $form_state->getFormObject()->getEntity();
  $identifier = $node->id() ? $node->id() : $node->uuid();

  try {
    $queue_storage = \Drupal::entityTypeManager()->getStorage('advancedqueue_queue');
    $queue = $queue_storage->load('ttd_topics_analysis');
    if ($queue) {
      $job = Job::create('ttd_topics_analysis', [
        'node_id' => $identifier,
        'force_analysis' => TRUE,
      ]);
      $queue->enqueueJob($job);

      // Set the analysis in progress flag.
      $node->set('field_ttd_analysis_in_progress', TRUE);
      $node->save();

      $message = t('Analysis has been queued and will run in the background. Please check back in a few minutes.');
    }
    else {
      $message = t('Error: TTD Topics analysis queue not found.');
    }
  }
  catch (\Exception $e) {
    $message = t('Error queueing TTD Topics analysis: @message', ['@message' => $e->getMessage()]);
    \Drupal::logger('topicalboost')->error('Error queueing TTD Topics analysis job: @message', ['@message' => $e->getMessage()]);
  }

  $response = new AjaxResponse();
  $response->addCommand(new ReplaceCommand(
    '#ttd-topics-run-analysis-wrapper',
    '<div id="ttd-topics-run-analysis-wrapper"><p>' . $message . '</p></div>'
  ));

  return $response;
}

/**
 * Implements hook_preprocess_html().
 *
 * Adds skeleton style body class if enabled.
 */
function ttd_topics_preprocess_html(&$variables) {
  $config = \Drupal::config('ttd_topics.settings');
  if ($config->get('skeleton_style')) {
    $variables['attributes']['class'][] = 'ttd-skeleton-style';
  }
}

/**
 * Implements hook_page_attachments().
 */
function ttd_topics_page_attachments(array &$attachments) {
  // Attach error telemetry JS on admin pages when enabled.
  $config = \Drupal::config('ttd_topics.settings');
  if ($config->get('error_telemetry_enabled') ?? TRUE) {
    $is_admin = \Drupal::service('router.admin_context')->isAdminRoute();
    if ($is_admin) {
      $attachments['#attached']['library'][] = 'ttd_topics/error_telemetry';
    }
  }

  $node = \Drupal::routeMatch()->getParameter('node');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);
  
  if ($node && in_array($node->bundle(), $enabled_content_types)) {
    try {
      $debug = (bool) $config->get('debug_mode');
      if ($debug) {
        \Drupal::logger('topicalboost')->debug('Starting schema generation for node @nid', ['@nid' => $node->id()]);
      }

      $schema_generator = \Drupal::service('ttd_topics.schema_generator');
      $schema_data = $schema_generator->getNodeTopicsSchema($node->id());

      if ($debug) {
        \Drupal::logger('topicalboost')->debug('Schema data: @data', ['@data' => print_r($schema_data, TRUE)]);
      }

      if (!empty($schema_data) && !empty($schema_data['@graph'])) {
        $attachments['#attached']['html_head'][] = [
          [
            '#type' => 'html_tag',
            '#tag' => 'script',
            '#value' => json_encode($schema_data, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES),
            '#attributes' => [
              'type' => 'application/ld+json',
              'class' => 'schema-graph',
            ],
          ],
          'topicalboost_schema',
        ];
      }
    }
    catch (\Exception $e) {
      \Drupal::logger('topicalboost')->error('Schema generation error: @message', [
        '@message' => $e->getMessage(),
        '@trace' => $e->getTraceAsString(),
      ]);
    }
  }
}

/**
 * Implements hook_simple_sitemap_links_alter().
 */
function ttd_topics_simple_sitemap_links_alter(array &$links) {
  // Get minimum display count from config.
  $config = \Drupal::config('ttd_topics.settings');
  $min_display_count = $config->get('post_topic_minimum_display_count');

  foreach ($links as $key => $link) {
    // Check if this is a taxonomy term link for topicalboost.
    if (isset($link['entity_info'])
        && $link['entity_info']['entity_type'] === 'taxonomy_term'
        && $link['entity_info']['bundle'] === 'topicalboost') {

      $term = \Drupal::entityTypeManager()
        ->getStorage('taxonomy_term')
        ->load($link['entity_info']['id']);

      if ($term) {
        // Check if term is hidden.
        if ($term->get('field_hide')->value) {
          unset($links[$key]);
          continue;
        }

        // Check post count.
        $count = \Drupal::database()->select('taxonomy_index', 'ti')
          ->condition('tid', $term->id())
          ->countQuery()
          ->execute()
          ->fetchField();

        if ($count < $min_display_count) {
          unset($links[$key]);
        }
      }
    }
  }
}

/**
 * Get node counts for topic terms.
 *
 * @param array $term_ids
 *   Array of term IDs.
 *
 * @return array
 *   Array of term ID => count pairs.
 */
function ttd_topics_get_topic_node_counts(array $term_ids) {
  if (empty($term_ids)) {
    return [];
  }

  $database = \Drupal::database();
  $query = $database->select('taxonomy_index', 'ti')
    ->fields('ti', ['tid'])
    ->condition('tid', $term_ids, 'IN')
    ->groupBy('tid');
  $query->addExpression('COUNT(nid)', 'count');

  $results = $query->execute()->fetchAllKeyed();

  // Ensure all term IDs are present in the result.
  $counts = [];
  foreach ($term_ids as $tid) {
    $counts[$tid] = isset($results[$tid]) ? (int) $results[$tid] : 0;
  }

  return $counts;
}

/**
 * Implements hook_form_FORM_ID_alter() for taxonomy_overview_terms.
 *
 * Adds a search filter and improved overview.
 */
function ttd_topics_form_taxonomy_overview_terms_alter(&$form, FormStateInterface $form_state, $form_id) {
  $vocabulary = $form_state->getBuildInfo()['args'][0] ?? NULL;

  if ($vocabulary && $vocabulary->id() === 'ttd_topics') {
    // Hide the default terms table to avoid duplication.
    if (isset($form['terms'])) {
      $form['terms']['#access'] = FALSE;
    }

    // Add search filter form.
    $search = \Drupal::request()->query->get('search', '');
    $min_posts = \Drupal::request()->query->get('min_posts', '');

    $form['search_filter'] = [
      '#type' => 'details',
      '#title' => t('Filter topics'),
      '#open' => TRUE,
      '#weight' => -100,
      '#attributes' => ['class' => ['container-inline']],
    ];

    $form['search_filter']['search'] = [
      '#type' => 'search',
      '#title' => t('Search'),
      '#title_display' => 'invisible',
      '#placeholder' => t('Filter by topic name...'),
      '#default_value' => $search,
      '#size' => 25,
    ];

    $form['search_filter']['min_posts'] = [
      '#type' => 'select',
      '#title' => t('Minimum posts'),
      '#title_display' => 'invisible',
      '#options' => [
        '' => t('Any post count'),
        '1' => t('1+ posts'),
        '5' => t('5+ posts'),
        '10' => t('10+ posts'),
        '25' => t('25+ posts'),
        '50' => t('50+ posts'),
        '100' => t('100+ posts'),
      ],
      '#default_value' => $min_posts,
    ];

    $form['search_filter']['submit'] = [
      '#type' => 'submit',
      '#value' => t('Filter'),
      '#submit' => ['ttd_topics_search_submit'],
      '#button_type' => 'primary',
    ];

    if (!empty($search) || !empty($min_posts)) {
      $form['search_filter']['reset'] = [
        '#type' => 'submit',
        '#value' => t('Reset'),
        '#submit' => ['ttd_topics_search_reset'],
      ];
    }

    // Load the controller output.
    $controller = \Drupal::service('class_resolver')->getInstanceFromDefinition('Drupal\\ttd_topics\\Controller\\TtdTopicsController');
    $overview_build = $controller->overviewPage();

    // Insert our overview near the top.
    $form['topicalboost_overview_custom'] = $overview_build + ['#weight' => -50];

    // Remove all the default taxonomy form elements that aren't needed.
    $elements_to_hide = [
      'description',
      '#description',
      'pager',
      'actions',
      'reset_alphabetical',
    ];

    foreach ($elements_to_hide as $element) {
      if (isset($form[$element])) {
        unset($form[$element]);
      }
    }

    // Also try to remove any description attached to the form itself.
    if (isset($form['#description'])) {
      unset($form['#description']);
    }

    // Hide the drag-and-drop help text that appears below the table.
    if (isset($form['#suffix'])) {
      $form['#suffix'] = '';
    }

    // Remove any other help text elements that might contain the drag-and-drop message.
    $help_elements = ['help', '#help', 'help_text', '#help_text'];
    foreach ($help_elements as $help_element) {
      if (isset($form[$help_element])) {
        $form[$help_element]['#access'] = FALSE;
      }
    }
  }
}

/**
 * Submit handler for search filter.
 */
function ttd_topics_search_submit(array &$form, FormStateInterface $form_state) {
  $search = $form_state->getValue('search');
  $min_posts = $form_state->getValue('min_posts');
  $current_path = \Drupal::request()->getPathInfo();

  $query_params = [];
  if (!empty($search)) {
    $query_params['search'] = $search;
  }
  if (!empty($min_posts)) {
    $query_params['min_posts'] = $min_posts;
  }

  $url = Url::fromUserInput($current_path, ['query' => $query_params]);
  $form_state->setRedirectUrl($url);
}

/**
 * Submit handler for search reset.
 */
function ttd_topics_search_reset(array &$form, FormStateInterface $form_state) {
  $current_path = \Drupal::request()->getPathInfo();
  $url = Url::fromUserInput($current_path);
  $form_state->setRedirectUrl($url);
}

/**
 * Submit handler to save pinned posts from the taxonomy term form.
 */
function ttd_topics_pinned_posts_submit(array &$form, FormStateInterface $form_state) {
  $term = $form_state->getFormObject()->getEntity();
  if (!$term->hasField('field_pinned_posts')) {
    return;
  }

  $pinned_nids_value = $form_state->getValue('pinned_nids');
  $pinned_nids = [];
  if (!empty($pinned_nids_value)) {
    $pinned_nids = array_filter(array_map('intval', explode(',', $pinned_nids_value)));
  }

  // Limit to 3 pinned posts.
  $pinned_nids = array_slice($pinned_nids, 0, 3);

  $references = [];
  foreach ($pinned_nids as $nid) {
    $references[] = ['target_id' => $nid];
  }

  $term->set('field_pinned_posts', $references);
  $term->save();
}

/**
 * Implements hook_views_pre_render().
 *
 * Injects pinned posts at the top of taxonomy term page views for ttd_topics.
 */
function ttd_topics_views_pre_render(\Drupal\views\ViewExecutable $view) {
  // Only target the taxonomy term page view.
  if ($view->id() !== 'taxonomy_term' || $view->current_display !== 'page_1') {
    return;
  }

  // Check if we're viewing a ttd_topics term.
  $term = \Drupal::routeMatch()->getParameter('taxonomy_term');
  if (!$term || $term->bundle() !== 'ttd_topics') {
    return;
  }

  if (!$term->hasField('field_pinned_posts') || $term->get('field_pinned_posts')->isEmpty()) {
    return;
  }

  $pinned_nids = [];
  foreach ($term->get('field_pinned_posts') as $ref) {
    if ($ref->target_id) {
      $pinned_nids[] = (int) $ref->target_id;
    }
  }

  if (empty($pinned_nids)) {
    return;
  }

  // Load pinned nodes and create view result rows.
  $node_storage = \Drupal::entityTypeManager()->getStorage('node');
  $pinned_rows = [];
  $existing_nids = [];

  foreach ($view->result as $row) {
    if (isset($row->nid)) {
      $existing_nids[] = (int) $row->nid;
    }
  }

  foreach ($pinned_nids as $nid) {
    $node = $node_storage->load($nid);
    if (!$node || !$node->isPublished()) {
      continue;
    }

    // Create a result row for this pinned node.
    $row = new \Drupal\views\ResultRow();
    $row->_entity = $node;
    $row->nid = $node->id();
    $row->_pinned = TRUE;
    $pinned_rows[] = $row;

    // Remove from existing results if already present to avoid duplicates.
    foreach ($view->result as $key => $existing_row) {
      if (isset($existing_row->nid) && (int) $existing_row->nid === $nid) {
        unset($view->result[$key]);
        break;
      }
    }
  }

  // Prepend pinned rows.
  if (!empty($pinned_rows)) {
    $view->result = array_merge($pinned_rows, array_values($view->result));
    // Re-index.
    $view->result = array_values($view->result);
    foreach ($view->result as $index => $row) {
      $row->index = $index;
    }
  }
}

/**
 * Implements hook_url_inbound_alter().
 * Provides custom routing for the improved overview page.
 */
function ttd_topics_url_inbound_alter(&$path, $original_path, $path_language) {
  if ($path === '/admin/config/content/ttd-topics/test-overview') {
    $path = '/ttd-topics/test-overview';
  }
}

/**
 * Custom page callback for improved topics overview.
 */
function ttd_topics_improved_overview_page() {
  $controller = new TtdTopicsController();
  return $controller->overviewPage();
}

/**
 * Implements hook_page_top().
 *
 * Simple redirect approach to handle /overview path.
 */
function ttd_topics_page_top(array &$page_top) {
  $current_path = \Drupal::service('path.current')->getPath();
  if ($current_path === '/admin/config/content/ttd-topics/overview') {
    $response = new RedirectResponse('/admin/config/content/ttd-topics?view=overview');
    $response->send();
    exit;
  }
}

/**
 * Demand metrics cache TTL in seconds (90 days to match API and WordPress).
 */
const TTD_DEMAND_CACHE_TTL = 90 * 24 * 60 * 60; // 7,776,000 seconds

/**
 * Get demand metrics from cache.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 *
 * @return array|null
 *   Demand metrics data array or NULL if cache miss/expired.
 */
function ttd_get_demand_metrics($term_or_keyword) {
  $cache_key = ttd_get_demand_cache_key($term_or_keyword);
  $cached_data = \Drupal::state()->get($cache_key);

  if (!$cached_data) {
    return NULL;
  }

  // Check if cache is still valid
  if (isset($cached_data['fetched_at'])) {
    $fetched_time = strtotime($cached_data['fetched_at']);
    $expiry_time = $fetched_time + TTD_DEMAND_CACHE_TTL;

    if (time() >= $expiry_time) {
      // Cache expired - delete and return null
      \Drupal::state()->delete($cache_key);
      return NULL;
    }
  }

  return $cached_data;
}

/**
 * Store demand metrics in cache.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 * @param array $metrics_data
 *   Demand metrics data to store (keyword_difficulty, search_volume).
 *
 * @return bool
 *   TRUE on success.
 */
function ttd_store_demand_metrics($term_or_keyword, array $metrics_data) {
  $cache_key = ttd_get_demand_cache_key($term_or_keyword);

  // Add timestamp to the data
  $cache_data = array_merge($metrics_data, [
    'fetched_at' => gmdate('c'),
  ]);

  \Drupal::state()->set($cache_key, $cache_data);
  return TRUE;
}

/**
 * Generate cache key for demand metrics.
 *
 * @param string|int $term_or_keyword
 *   Term ID (numeric) or keyword string.
 *
 * @return string
 *   Cache key string.
 */
function ttd_get_demand_cache_key($term_or_keyword) {
  if (is_numeric($term_or_keyword)) {
    // Entity topic (by term_id)
    return 'ttd_demand_metrics_entity_' . intval($term_or_keyword);
  }
  else {
    // Manual topic (by keyword)
    return 'ttd_demand_metrics_keyword_' . md5($term_or_keyword);
  }
}

/**
 * Get salience category for a term on a specific node.
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string|null
 *   The salience category ('about' or 'mentions') or NULL if not found.
 */
function ttd_get_term_salience_category($term_id, $node_id) {
  $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($term_id);
  if (!$term || !$term->hasField('field_ttd_id')) {
    return NULL;
  }
  $ttd_id = $term->get('field_ttd_id')->value;
  if (!$ttd_id) {
    return NULL;
  }

  $database = \Drupal::database();
  $salience_category = $database->select('ttd_entity_post_ids', 'ep')
    ->fields('ep', ['salience_category'])
    ->condition('entity_id', $ttd_id)
    ->condition('post_id', $node_id)
    ->execute()
    ->fetchField();

  return $salience_category ?: NULL;
}

/**
 * Get salience data for all entities on a node.
 *
 * Returns array indexed by ttd_id with salience_score and salience_category.
 * Used by frontend display to order topics by relevance.
 *
 * @param int $node_id
 *   The node ID.
 *
 * @return array
 *   Array of [ttd_id => ['salience_score' => float|null, 'salience_category' => string|null]].
 */
function ttd_get_node_salience_data($node_id) {
  $database = \Drupal::database();
  $results = $database->select('ttd_entity_post_ids', 'ep')
    ->fields('ep', ['entity_id', 'salience_score', 'salience_category'])
    ->condition('post_id', $node_id)
    ->execute()
    ->fetchAll();

  $salience_map = [];
  foreach ($results as $row) {
    $salience_map[(int) $row->entity_id] = [
      'salience_score' => $row->salience_score !== NULL ? (float) $row->salience_score : NULL,
      'salience_category' => $row->salience_category,
    ];
  }

  return $salience_map;
}

/**
 * Get KD difficulty color based on value.
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   Hex color code.
 */
function ttd_get_kd_color($difficulty) {
  if ($difficulty >= 90) {
    return '#dc2626';
  }
  if ($difficulty >= 70) {
    return '#ea580c';
  }
  if ($difficulty >= 50) {
    return '#ca8a04';
  }
  if ($difficulty >= 30) {
    return '#65a30d';
  }
  return '#16a34a';
}

/**
 * Get difficulty label for a KD value.
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   Human-readable difficulty label.
 */
function ttd_get_kd_label($difficulty) {
  if ($difficulty <= 30) {
    return 'Easy';
  }
  if ($difficulty <= 60) {
    return 'Medium';
  }
  if ($difficulty <= 80) {
    return 'Hard';
  }
  return 'Very Hard';
}

/**
 * Format volume with K/M notation.
 *
 * @param int $volume
 *   Search volume value.
 *
 * @return string
 *   Formatted volume string.
 */
function ttd_format_volume($volume) {
  if (!$volume && $volume !== 0) {
    return '--';
  }
  $num = (int) $volume;
  if ($num >= 1000000) {
    return round($num / 1000000, 1) . 'M';
  }
  if ($num >= 1000) {
    return round($num / 1000, 1) . 'K';
  }
  return (string) $num;
}

/**
 * Get KD badge markup for a term (About topics only).
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   HTML markup for the KD badge, or empty string if not applicable.
 */
function ttd_get_kd_badge($term_id, $node_id) {
  // Check if this is an About topic.
  $salience = ttd_get_term_salience_category($term_id, $node_id);
  if ($salience !== 'about') {
    return '';
  }

  // Get cached demand metrics.
  $metrics = ttd_get_demand_metrics($term_id);
  if (!$metrics || !isset($metrics['keyword_difficulty'])) {
    return '';
  }

  $kd = (int) $metrics['keyword_difficulty'];
  $sv = isset($metrics['search_volume']) ? (int) $metrics['search_volume'] : 0;
  $color = ttd_get_kd_color($kd);
  $label = ttd_get_kd_label($kd);
  $sv_formatted = ttd_format_volume($sv);

  $tooltip = t('Monthly search volume: @volume | Difficulty: @kd/100 (@label)', [
    '@volume' => $sv_formatted,
    '@kd' => $kd,
    '@label' => $label,
  ]);

  return '<span class="ttd-kd-badge" style="color: ' . $color . ';" title="' . $tooltip . '">' . $sv_formatted . '</span>';
}

/**
 * Ensure the ttd_topics Pathauto pattern exists.
 *
 * This helper is used during install and whenever Pathauto is installed
 * afterwards, guaranteeing that topic terms always receive friendly aliases.
 */
function ttd_topics_ensure_pathauto_pattern() {
  /** @var \Drupal\Core\Entity\EntityStorageInterface $pattern_storage */
  $pattern_storage = \Drupal::entityTypeManager()->getStorage('pathauto_pattern');

  // Bail if the pattern already exists.
  if ($pattern_storage->load('ttd_topics')) {
    return;
  }

  // Determine the desired prefix from configuration, defaulting to /topics/.
  $config = \Drupal::configFactory()->getEditable('ttd_topics.settings');
  $prefix = $config->get('topic_url_path_prefix') ?: '/topics/';
  $prefix = '/' . trim($prefix, '/') . '/';

  $pattern = $prefix . '[term:name]';

  // Create the pattern entity.
  $pattern_storage->create([
    'id' => 'ttd_topics',
    'label' => 'TTD Topics',
    'type' => 'canonical_entities:taxonomy_term',
    'pattern' => $pattern,
    'selection_criteria' => [
      [
        'id' => 'entity_bundle:taxonomy_term',
        'bundles' => ['ttd_topics' => 'ttd_topics'],
        'negate' => FALSE,
        'context_mapping' => ['taxonomy_term' => 'taxonomy_term'],
      ],
    ],
    'weight' => 0,
    'status' => TRUE,
  ])->save();

  // Clear caches so the new pattern is recognised immediately.
  \Drupal::service('plugin.manager.alias_type')->clearCachedDefinitions();
  \Drupal::messenger()->addMessage(t('Pathauto pattern for TTD Topics was created automatically.'));
}

/**
 * Implements hook_modules_installed().
 *
 * Creates the Pathauto pattern if Pathauto is enabled after TopicalBoost.
 */
function ttd_topics_modules_installed($modules) {
  if (in_array('pathauto', $modules, TRUE)) {
    ttd_topics_ensure_pathauto_pattern();
  }
}

/**
 * Get the effective tier for a topic on a node (WP beta features).
 *
 * Priority: tier_overrides > salience_category > default ('mentions').
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   The tier: 'mainEntity', 'about', 'mentions', or 'below-threshold'.
 */
function ttd_get_topic_tier($term_id, $node_id) {
  $node = \Drupal::entityTypeManager()->getStorage('node')->load($node_id);
  if (!$node) {
    return 'mentions';
  }

  // Get term's ttd_id
  $term = \Drupal::entityTypeManager()->getStorage('taxonomy_term')->load($term_id);
  if (!$term || !$term->hasField('field_ttd_id')) {
    return 'mentions';
  }
  $ttd_id = $term->get('field_ttd_id')->value;

  // Check tier_overrides first (highest priority)
  $tier_overrides = $node->get('field_tier_overrides')->value ?? [];
  if (is_array($tier_overrides)) {
    // Check by ttd_id
    if ($ttd_id && isset($tier_overrides[(string) $ttd_id])) {
      return $tier_overrides[(string) $ttd_id];
    }
    // Check by term_id
    $term_key = 'term_' . $term_id;
    if (isset($tier_overrides[$term_key])) {
      return $tier_overrides[$term_key];
    }
  }

  // Fall back to salience_category from database
  if ($ttd_id) {
    $database = \Drupal::database();
    $salience_category = $database->select('ttd_entity_post_ids', 'ep')
      ->fields('ep', ['salience_category'])
      ->condition('entity_id', $ttd_id)
      ->condition('post_id', $node_id)
      ->execute()
      ->fetchField();

    if ($salience_category) {
      return $salience_category;
    }
  }

  // Default to 'mentions'
  return 'mentions';
}

/**
 * Format count with K/M notation (WP beta features).
 *
 * @param int $count
 *   The count value.
 *
 * @return string
 *   Formatted count string.
 */
function ttd_format_count($count) {
  if (!$count && $count !== 0) {
    return '--';
  }
  $num = (int) $count;
  if ($num >= 1000000) {
    $val = $num / 1000000;
    return rtrim(rtrim(number_format($val, 1), '0'), '.') . 'M';
  }
  if ($num >= 1000) {
    $val = $num / 1000;
    return rtrim(rtrim(number_format($val, 1), '0'), '.') . 'K';
  }
  return (string) $num;
}

/**
 * Get CSS class for keyword difficulty (WP beta features).
 *
 * @param int $difficulty
 *   Keyword difficulty value (0-100).
 *
 * @return string
 *   CSS class name.
 */
function ttd_get_kd_class($difficulty) {
  if ($difficulty <= 30) {
    return 'ttd-kd-easy';
  }
  if ($difficulty <= 60) {
    return 'ttd-kd-medium';
  }
  if ($difficulty <= 80) {
    return 'ttd-kd-hard';
  }
  return 'ttd-kd-very-hard';
}

/**
 * Render KD badge for focus topics (WP beta features).
 *
 * @param int $term_id
 *   The taxonomy term ID.
 * @param int $node_id
 *   The node ID.
 *
 * @return string
 *   HTML markup for the KD badge, or empty string.
 */
function ttd_render_kd_badge($term_id, $node_id) {
  $tier = ttd_get_topic_tier($term_id, $node_id);

  // Only show badges for mainEntity and about tiers
  if (!in_array($tier, ['mainEntity', 'about'])) {
    return '';
  }

  // Get cached demand metrics
  $metrics = ttd_get_demand_metrics($term_id);
  if (!$metrics || !isset($metrics['keyword_difficulty'], $metrics['traffic_potential'])) {
    return '<span class="ttd-kd-badge ttd-kd-no-data" title="Click to fetch demand data">--</span>';
  }

  $kd = (int) $metrics['keyword_difficulty'];
  $tp = (int) $metrics['traffic_potential'];
  $kd_class = ttd_get_kd_class($kd);
  $label = ttd_get_kd_label($kd);
  $tp_formatted = ttd_format_count($tp);

  $tooltip = t('Traffic Potential: @tp | Difficulty: @kd/100 (@label) | Click to refresh', [
    '@tp' => $tp_formatted,
    '@kd' => $kd,
    '@label' => $label,
  ]);

  return '<span class="ttd-kd-badge ' . $kd_class . '" title="' . $tooltip . '" data-term-id="' . $term_id . '">' . $tp_formatted . '</span>';
}
