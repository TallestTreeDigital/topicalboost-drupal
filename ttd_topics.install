    'author_image_field' => '',
    'author_description_field' => '',
  ];
}

/**
 * Ensures current config defaults exist without overwriting saved values.
 */
function ttd_topics_ensure_default_settings() {
  $config_factory = \Drupal::configFactory();
  $config = $config_factory->getEditable('ttd_topics.settings');
  $legacy_config = $config_factory->get('topicalboost.settings');

  foreach (ttd_topics_default_settings() as $key => $default_value) {
    if ($config->get($key) !== NULL) {
      continue;
    }

    $legacy_value = !$legacy_config->isNew() ? $legacy_config->get($key) : NULL;
    $config->set($key, $legacy_value !== NULL ? $legacy_value : $default_value);
  }

  $config->save();
}

/**
 * Implements hook_install().
 */
function ttd_topics_install() {
  // Create the ttd_topics vocabulary.
  if (!Vocabulary::load('ttd_topics')) {
    $vocabulary = Vocabulary::create([
      'vid' => 'ttd_topics',
      'description' => 'Vocabulary for TopicalBoost',
      'name' => 'Topics',
    ]);
    $vocabulary->save();
  }

  // Define all field storage configs.
  $field_storage_configs = [
    [
      'field_name' => 'field_ttd_rejected_topics',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'taxonomy_term',
        'handler' => 'default:taxonomy_term',
        'handler_settings' => [
          'target_bundles' => [
            'ttd_topics' => 'ttd_topics',
          ],
          'auto_create' => FALSE,
        ],
      ],
      'cardinality' => -1,
    ],
    [
      'field_name' => 'field_ttd_last_analyzed',
      'entity_type' => 'node',
      'type' => 'datetime',
      'settings' => ['datetime_type' => 'datetime'],
    ],
    [
      'field_name' => 'field_ttd_topics',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => ['target_type' => 'taxonomy_term', 'handler' => 'default'],
      'cardinality' => -1,
    ],
    [
      'field_name' => 'field_ttd_analysis_in_progress',
      'entity_type' => 'node',
      'type' => 'boolean',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_generated_meta_title',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_generated_meta_desc',
      'entity_type' => 'node',
      'type' => 'string_long',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_generated_og_title',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_generated_og_desc',
      'entity_type' => 'node',
      'type' => 'string_long',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_tier_overrides',
      'entity_type' => 'node',
      'type' => 'map',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_manual_topics',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'taxonomy_term',
      ],
      'cardinality' => -1,
    ],
    [
      'field_name' => 'field_ttd_schema_16x9',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_schema_4x3',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_schema_1x1',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_ttd_schema_focal_point',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
    ],
  ];

  // Create field storages.
  foreach ($field_storage_configs as $field_storage_config) {
    if (!FieldStorageConfig::loadByName($field_storage_config['entity_type'], $field_storage_config['field_name'])) {
      FieldStorageConfig::create($field_storage_config)->save();
    }
  }

  // Note: Fields will be added to content types when they are enabled in the module settings.
  // This ensures the module works with any site's content type configuration.

  // Add fields to taxonomy terms.
  $term_field_storage_configs = [
    [
      'field_name' => 'field_ttd_id',
      'entity_type' => 'taxonomy_term',
      'type' => 'string',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_hide',
      'entity_type' => 'taxonomy_term',
      'type' => 'boolean',
      'cardinality' => 1,
    ],
    [
      'field_name' => 'field_pinned_posts',
      'entity_type' => 'taxonomy_term',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'node',
      ],
      'cardinality' => 3,
    ],
    [
      'field_name' => 'field_force_show',
      'entity_type' => 'taxonomy_term',
      'type' => 'boolean',
      'cardinality' => 1,
    ],
  ];

  foreach ($term_field_storage_configs as $field_storage_config) {
    if (!FieldStorageConfig::loadByName($field_storage_config['entity_type'], $field_storage_config['field_name'])) {
      FieldStorageConfig::create($field_storage_config)->save();
    }
  }

  foreach ($term_field_storage_configs as $field_storage_config) {
    if (!FieldConfig::loadByName('taxonomy_term', 'ttd_topics', $field_storage_config['field_name'])) {
      FieldConfig::create([
        'field_name' => $field_storage_config['field_name'],
        'entity_type' => 'taxonomy_term',
        'bundle' => 'ttd_topics',
        'label' => ucfirst(str_replace('_', ' ', $field_storage_config['field_name'])),
      ])->save();
    }
  }

  // Create the TTD Topics analysis queue.
  if (!Queue::load('ttd_topics_analysis')) {
    Queue::create([
      'id' => 'ttd_topics_analysis',
      'label' => 'TopicalBoost Analysis',
      'backend' => 'database',
      'processor' => 'cron',
    ])->save();
  }

  // Create pathauto pattern for TTD Topics using helper function.
  ttd_topics_ensure_pathauto_pattern();

  // Configure the form display for ttd_topics vocabulary.
  $form_display = EntityFormDisplay::load('taxonomy_term.ttd_topics.default');
  if (!$form_display) {
    $form_display = EntityFormDisplay::create([
      'targetEntityType' => 'taxonomy_term',
      'bundle' => 'ttd_topics',
      'mode' => 'default',
      'status' => TRUE,
    ]);
    $form_display->save();

    $form_display->setComponent('field_hide', [
      'type' => 'boolean_checkbox',
      'weight' => 1,
      'settings' => [
        'display_label' => TRUE,
      ],
    ]);
    $form_display->save();
  }

  // Configure the view display.
  $view_display = EntityViewDisplay::create([
    'targetEntityType' => 'taxonomy_term',
    'bundle' => 'ttd_topics',
    'mode' => 'default',
    'status' => TRUE,
    'content' => [
      'description' => [
        'type' => 'text_default',
        'weight' => 0,
        'label' => 'hidden',
        'settings' => [],
        'third_party_settings' => [],
      ],
    ],
    'hidden' => [
      'field_hide' => TRUE,
      'field_ttd_id' => TRUE,
      'field_pinned_posts' => TRUE,
      'field_force_show' => TRUE,
    ],
    'dependencies' => [
      'config' => [
        'taxonomy.vocabulary.ttd_topics',
      ],
      'module' => [
        'text',
      ],
    ],
  ]);
  $view_display->save();

  // Create directory for logo uploads.
  $directory = 'public://logos';
  \Drupal::service('file_system')->prepareDirectory($directory, FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS);

  // Set default configuration.
  ttd_topics_ensure_default_settings();

  // Grant permissions to administrator role by default so users can actually use the module.
  $admin_role = \Drupal\user\Entity\Role::load('administrator');
  if ($admin_role) {
    $admin_role->grantPermission('administer topicalboost configuration');
    $admin_role->grantPermission('administer topicalboost');
    $admin_role->save();
  }
}

/**
 * Implements hook_uninstall().
 */
function ttd_topics_uninstall() {
  $database = \Drupal::database();

  // Remove all ttd_topics terms using proper entity deletion.
  $term_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_term');
  $terms = $term_storage->loadByProperties(['vid' => 'ttd_topics']);
  if (!empty($terms)) {
    $term_storage->delete($terms);
  }

  // Delete the vocabulary itself.
  $vocabulary_storage = \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary');
  $vocabulary = $vocabulary_storage->load('ttd_topics');
  if ($vocabulary) {
    $vocabulary->delete();
  }

  // Drop custom TTD tables.
  $ttd_tables = [
    'ttd_entity_wb_categories',
    'ttd_entity_schema_types',
    'ttd_entity_post_ids',
    'ttd_wb_categories',
    'ttd_schema_types',
    'ttd_entities',
  ];

  foreach ($ttd_tables as $table) {
    if ($database->schema()->tableExists($table)) {
      $database->schema()->dropTable($table);
    }
  }

  // Remove all related config properly using Drupal's config system.
  $config_factory = \Drupal::configFactory();
  $config_names = [
    'taxonomy.vocabulary.ttd_topics',
    'pathauto.pattern.ttd_topics',
    'advancedqueue.advancedqueue_queue.ttd_topics_analysis',
    'core.entity_form_display.taxonomy_term.ttd_topics.default',
    'core.entity_view_display.taxonomy_term.ttd_topics.default',
    'field.storage.node.field_ttd_last_analyzed',
    'field.storage.node.field_ttd_topics',
    'field.storage.node.field_ttd_rejected_topics',
    'field.storage.node.field_ttd_analysis_in_progress',
    'field.storage.node.field_ttd_generated_meta_title',
    'field.storage.node.field_ttd_generated_meta_desc',
    'field.storage.node.field_ttd_generated_og_title',
    'field.storage.node.field_ttd_generated_og_desc',
    'field.storage.node.field_tier_overrides',
    'field.storage.node.field_manual_topics',
    'field.storage.node.field_ttd_schema_16x9',
    'field.storage.node.field_ttd_schema_4x3',
    'field.storage.node.field_ttd_schema_1x1',
    'field.storage.node.field_ttd_schema_focal_point',
    'field.storage.taxonomy_term.field_ttd_id',
    'field.storage.taxonomy_term.field_hide',
    'field.storage.taxonomy_term.field_pinned_posts',
    'field.storage.taxonomy_term.field_force_show',
    'ttd_topics.settings',
    'topicalboost.settings',
  ];

  foreach ($config_names as $config_name) {
    $config = $config_factory->getEditable($config_name);
    if (!$config->isNew()) {
      $config->delete();
    }
  }

  // Clear entity caches.
  \Drupal::entityTypeManager()->getStorage('taxonomy_term')->resetCache();
  \Drupal::entityTypeManager()->getStorage('taxonomy_vocabulary')->resetCache();
}

/**
 * Add analysis_custom_fields config key with default empty value.
 */
function ttd_topics_update_8001() {
  $config = \Drupal::configFactory()->getEditable('ttd_topics.settings');

  // Only set the key if it doesn't exist to preserve any early-adopter custom overrides
  if (!$config->get('analysis_custom_fields')) {
    $config->set('analysis_custom_fields', [])->save();
  }

  return t('Added analysis_custom_fields configuration key for custom field analysis feature.');
}

/**
 * Add salience_score and salience_category columns to ttd_entity_post_ids table.
 */
function ttd_topics_update_8002() {
  $database = \Drupal::database();
  $schema = $database->schema();

  // Add salience_score column if it doesn't exist
  if (!$schema->fieldExists('ttd_entity_post_ids', 'salience_score')) {
    $schema->addField('ttd_entity_post_ids', 'salience_score', [
      'type' => 'float',
      'not null' => FALSE,
      'description' => 'Salience score (0-1)',
    ]);
  }

  // Add salience_category column if it doesn't exist
  if (!$schema->fieldExists('ttd_entity_post_ids', 'salience_category')) {
    $schema->addField('ttd_entity_post_ids', 'salience_category', [
      'type' => 'varchar',
      'length' => 16,
      'not null' => FALSE,
      'description' => 'Salience category (about or mentions)',
    ]);

    // Add index on salience_category
    $schema->addIndex('ttd_entity_post_ids', 'salience_category', ['salience_category'], [
      'fields' => [
        'salience_category' => [
          'type' => 'varchar',
          'length' => 16,
          'not null' => FALSE,
        ],
      ],
    ]);
  }

  return t('Added salience_score and salience_category columns to ttd_entity_post_ids table.');
}

/**
 * Add field storage for SEO meta title and description fields.
 */
function ttd_topics_update_8003() {
  $meta_field_storage_configs = [
    [
      'field_name' => 'field_ttd_generated_meta_title',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
      'label' => 'TopicalBoost Generated Meta Title',
    ],
    [
      'field_name' => 'field_ttd_generated_meta_desc',
      'entity_type' => 'node',
      'type' => 'string_long',
      'cardinality' => 1,
      'label' => 'TopicalBoost Generated Meta Description',
    ],
  ];

  // Create field storages.
  foreach ($meta_field_storage_configs as $field_storage_config) {
    if (!FieldStorageConfig::loadByName($field_storage_config['entity_type'], $field_storage_config['field_name'])) {
      FieldStorageConfig::create([
        'field_name' => $field_storage_config['field_name'],
        'entity_type' => $field_storage_config['entity_type'],
        'type' => $field_storage_config['type'],
        'cardinality' => $field_storage_config['cardinality'],
      ])->save();
    }
  }

  // Add field instances to all enabled content types.
  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  foreach ($enabled_content_types as $content_type) {
    // Check if content type exists.
    if (!\Drupal::entityTypeManager()->getStorage('node_type')->load($content_type)) {
      continue;
    }

    foreach ($meta_field_storage_configs as $field_storage_config) {
      if (!FieldConfig::loadByName('node', $content_type, $field_storage_config['field_name'])) {
        FieldConfig::create([
          'field_name' => $field_storage_config['field_name'],
          'entity_type' => 'node',
          'bundle' => $content_type,
          'label' => $field_storage_config['label'],
        ])->save();
      }
    }
  }

  return t('Added field storage for SEO meta title and description fields.');
}

/**
 * Add tier_overrides and manual_topics field storage for WP beta features.
 */
function ttd_topics_update_9001() {
  // Add tier_overrides field (stores user-controlled tier assignments)
  if (!FieldStorageConfig::loadByName('node', 'field_tier_overrides')) {
    FieldStorageConfig::create([
      'field_name' => 'field_tier_overrides',
      'entity_type' => 'node',
      'type' => 'map',
      'cardinality' => 1,
    ])->save();
  }

  // Add manual_topics field (stores manually added topics)
  if (!FieldStorageConfig::loadByName('node', 'field_manual_topics')) {
    FieldStorageConfig::create([
      'field_name' => 'field_manual_topics',
      'entity_type' => 'node',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'taxonomy_term',
        'handler' => 'default:taxonomy_term',
        'handler_settings' => [
          'target_bundles' => [
            'ttd_topics' => 'ttd_topics',
          ],
          'auto_create' => FALSE,
        ],
      ],
      'cardinality' => -1,
    ])->save();
  }

  // Add field instances to all enabled content types
  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  foreach ($enabled_content_types as $content_type) {
    // Check if content type exists
    if (!\Drupal::entityTypeManager()->getStorage('node_type')->load($content_type)) {
      continue;
    }

    // Add tier_overrides field
    if (!FieldConfig::loadByName('node', $content_type, 'field_tier_overrides')) {
      FieldConfig::create([
        'field_name' => 'field_tier_overrides',
        'entity_type' => 'node',
        'bundle' => $content_type,
        'label' => 'Topic Tier Overrides',
      ])->save();
    }

    // Add manual_topics field
    if (!FieldConfig::loadByName('node', $content_type, 'field_manual_topics')) {
      FieldConfig::create([
        'field_name' => 'field_manual_topics',
        'entity_type' => 'node',
        'bundle' => $content_type,
        'label' => 'Manual Topics',
      ])->save();
    }
  }

  return t('Added tier_overrides and manual_topics field storage for enhanced topic management.');
}

/**
 * Add field_pinned_posts entity reference field on ttd_topics taxonomy terms.
 */
function ttd_topics_update_9002() {
  // Create field storage for pinned_posts on taxonomy terms.
  if (!FieldStorageConfig::loadByName('taxonomy_term', 'field_pinned_posts')) {
    FieldStorageConfig::create([
      'field_name' => 'field_pinned_posts',
      'entity_type' => 'taxonomy_term',
      'type' => 'entity_reference',
      'settings' => [
        'target_type' => 'node',
      ],
      'cardinality' => 3,
    ])->save();
  }

  // Add field instance to the ttd_topics vocabulary.
  if (!FieldConfig::loadByName('taxonomy_term', 'ttd_topics', 'field_pinned_posts')) {
    FieldConfig::create([
      'field_name' => 'field_pinned_posts',
      'entity_type' => 'taxonomy_term',
      'bundle' => 'ttd_topics',
      'label' => 'Pinned Posts',
      'description' => 'Select up to 3 posts to pin at the top of this topic page.',
    ])->save();
  }

  // Hide from default view display.
  $view_display = EntityViewDisplay::load('taxonomy_term.ttd_topics.default');
  if ($view_display) {
    $view_display->removeComponent('field_pinned_posts');
    $view_display->save();
  }

  return t('Added field_pinned_posts entity reference field for pinned posts on topic term pages.');
}

/**
 * Add field_force_show boolean field on ttd_topics taxonomy terms.
 */
function ttd_topics_update_9003() {
  // Create field storage for force_show.
  if (!FieldStorageConfig::loadByName('taxonomy_term', 'field_force_show')) {
