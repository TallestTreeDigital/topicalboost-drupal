/**
 * Add schema image fields for nodes.
 */
function ttd_topics_update_9004() {
  $schema_image_fields = [
    [
      'field_name' => 'field_ttd_schema_16x9',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
      'label' => 'Schema Image (16:9)',
    ],
    [
      'field_name' => 'field_ttd_schema_4x3',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
      'label' => 'Schema Image (4:3)',
    ],
    [
      'field_name' => 'field_ttd_schema_1x1',
      'entity_type' => 'node',
      'type' => 'image',
      'cardinality' => 1,
      'label' => 'Schema Image (1:1)',
    ],
    [
      'field_name' => 'field_ttd_schema_focal_point',
      'entity_type' => 'node',
      'type' => 'string',
      'cardinality' => 1,
      'label' => 'Schema Image Focal Point',
    ],
  ];

  foreach ($schema_image_fields as $field_config) {
    if (!FieldStorageConfig::loadByName($field_config['entity_type'], $field_config['field_name'])) {
      $storage_config = [
        'field_name' => $field_config['field_name'],
        'entity_type' => $field_config['entity_type'],
        'type' => $field_config['type'],
        'cardinality' => $field_config['cardinality'],
      ];
      FieldStorageConfig::create($storage_config)->save();
    }
  }

  // Add field instances to all enabled content types.
  $config = \Drupal::config('ttd_topics.settings');
  $enabled_content_types = array_filter($config->get('enabled_content_types') ?: []);

  foreach ($enabled_content_types as $content_type) {
    if (!\Drupal::entityTypeManager()->getStorage('node_type')->load($content_type)) {
      continue;
    }
    foreach ($schema_image_fields as $field_config) {
      if (!FieldConfig::loadByName('node', $content_type, $field_config['field_name'])) {
        FieldConfig::create([
          'field_name' => $field_config['field_name'],
          'entity_type' => 'node',
          'bundle' => $content_type,
          'label' => $field_config['label'],
        ])->save();
      }
    }
  }

  // Create directory for schema images.
  $directory = 'public://schema-images';
  \Drupal::service('file_system')->prepareDirectory($directory, FileSystemInterface::CREATE_DIRECTORY | FileSystemInterface::MODIFY_PERMISSIONS);

  return t('Added schema image fields for 16:9, 4:3, and 1:1 aspect ratios.');
}

/**
 * Repair current config defaults and re-ensure feature field coverage.
 */
function ttd_topics_update_9005() {
  ttd_topics_ensure_default_settings();

  // Re-run idempotent field coverage for sites that had older updates marked
  // complete before the current feature set was fully represented.
  ttd_topics_update_9001();
  ttd_topics_update_9002();
  ttd_topics_update_9003();
  ttd_topics_update_9004();

  $og_fields = [
    'field_ttd_generated_og_title' => [
      'type' => 'string',
      'label' => 'TopicalBoost Generated OG Title',
    ],
    'field_ttd_generated_og_desc' => [
      'type' => 'string_long',
      'label' => 'TopicalBoost Generated OG Description',
    ],
  ];
  foreach ($og_fields as $field_name => $field_info) {
    if (!FieldStorageConfig::loadByName('node', $field_name)) {
      FieldStorageConfig::create([
        'field_name' => $field_name,
        'entity_type' => 'node',
        'type' => $field_info['type'],
        'cardinality' => 1,
      ])->save();
    }
  }

  $enabled_content_types = array_filter(\Drupal::config('ttd_topics.settings')->get('enabled_content_types') ?: []);
  foreach ($enabled_content_types as $content_type) {
    if (!\Drupal::entityTypeManager()->getStorage('node_type')->load($content_type)) {
      continue;
    }
    foreach ($og_fields as $field_name => $field_info) {
      if (!FieldConfig::loadByName('node', $content_type, $field_name)) {
        FieldConfig::create([
          'field_name' => $field_name,
          'entity_type' => 'node',
          'bundle' => $content_type,
          'label' => $field_info['label'],
        ])->save();
      }
    }
  }

  if (!Queue::load('ttd_topics_analysis')) {
    Queue::create([
      'id' => 'ttd_topics_analysis',
      'label' => 'TopicalBoost Analysis',
      'backend' => 'database',
      'processor' => 'cron',
    ])->save();
  }

  return t('Repaired TopicalBoost config defaults, queue config, and feature field coverage.');
}

/**
 * Add Knowledge Graph description storage for entity metadata.
 */
function ttd_topics_update_9006() {
  $schema = \Drupal::database()->schema();

  if ($schema->tableExists('ttd_entities') && !$schema->fieldExists('ttd_entities', 'kg_description')) {
    $schema->addField('ttd_entities', 'kg_description', [
      'type' => 'text',
      'not null' => FALSE,
      'description' => 'Knowledge Graph description',
    ]);
  }

  return t('Added Knowledge Graph description storage for TopicalBoost entities.');
}

/**
 * Remove the retired editor placement setting.
 */
function ttd_topics_update_9007() {
  $config_factory = \Drupal::configFactory();

  foreach (['ttd_topics.settings', 'topicalboost.settings'] as $config_name) {
    $config = $config_factory->getEditable($config_name);
    if (!$config->isNew()) {
      $config->clear('metabox_position')->save();
    }
  }

  return t('Removed retired TopicalBoost editor placement setting.');
}

/**
 * Clear queued legacy sync pull jobs before cursor-only sync processing.
 */
function ttd_topics_update_9008() {
  $deleted = 0;
  $database = \Drupal::database();

  if ($database->schema()->tableExists('advancedqueue')) {
    $deleted = $database->delete('advancedqueue')
      ->condition('queue_id', 'ttd_topics_analysis')
      ->condition('type', 'ttd_sync_pull')
      ->condition('state', 'processing', '<>')
      ->execute();
  }

  $state = \Drupal::state();
  $state->delete('ttd_active_sync');
  $state->delete('ttd_sync_status_cache');

  return t('Cleared @count queued TopicalBoost sync pull jobs for cursor pagination.', [
    '@count' => $deleted,
  ]);
}

/**
 * Preserve the 1.5.6 kg_description update number for live upgrade continuity.
 */
function ttd_topics_update_9100() {
  return ttd_topics_update_9006();
}

/**
 * Bridge sites already marked at 9100 onto the 2.0 parity update set.
 */
function ttd_topics_update_9101() {
  $update_callbacks = [
    'ttd_topics_update_8001',
    'ttd_topics_update_8002',
    'ttd_topics_update_8003',
    'ttd_topics_update_9001',
    'ttd_topics_update_9002',
    'ttd_topics_update_9003',
    'ttd_topics_update_9004',
    'ttd_topics_update_9005',
    'ttd_topics_update_9006',
    'ttd_topics_update_9007',
    'ttd_topics_update_9008',
  ];

  $messages = [];
  foreach ($update_callbacks as $callback) {
    if (function_exists($callback)) {
      $messages[] = $callback();
    }
  }

  return t('Replayed TopicalBoost parity update coverage for sites upgrading from 1.5.x schema 9100. @details', [
    '@details' => implode(' ', array_map('strval', $messages)),
  ]);
}

/**
 * Align hidden frontend topic ordering with WordPress parity behavior.
 */
function ttd_topics_update_9102() {
  $config_factory = \Drupal::configFactory();

  foreach (['ttd_topics.settings', 'topicalboost.settings'] as $config_name) {
    $config = $config_factory->getEditable($config_name);
    if (!$config->isNew()) {
      $config->set('frontend_sort_order', 'alphabetical')->save();
    }
  }

  return t('Aligned TopicalBoost frontend topic ordering with tier-first alphabetical display.');
}

/**
 * Add an index for node-to-topic relationship lookups by post_id.
 */
function ttd_topics_update_9103() {
  $schema = \Drupal::database()->schema();

  if (!$schema->tableExists('ttd_entity_post_ids')) {
    return t('Skipped TopicalBoost post_id index because the relationship table does not exist.');
  }

  if ($schema->indexExists('ttd_entity_post_ids', 'ttd_epi_post_id') || $schema->indexExists('ttd_entity_post_ids', 'post_id')) {
    return t('TopicalBoost post_id relationship index already exists.');
  }

  $schema->addIndex('ttd_entity_post_ids', 'ttd_epi_post_id', [['post_id', 191]], [
    'fields' => [
      'post_id' => [
        'type' => 'varchar',
        'length' => 1024,
        'not null' => TRUE,
      ],
    ],
  ]);

  return t('Added TopicalBoost post_id relationship index.');
}
