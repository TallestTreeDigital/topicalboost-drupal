  return [
    'enabled_content_types' => [],
    'enable_frontend' => FALSE,
    'enable_automatic_mentions' => TRUE,
    'enable_meta_generator' => FALSE,
    'maximum_visible_post_topics' => 5,
    'post_topic_minimum_display_count' => 10,
    'analysis_custom_fields' => [],
    'topics_list_label' => 'Topics on this page',
    'topic_url_path_prefix' => 'topics',
    'debug_mode' => FALSE,
    'topicalboost_api_key' => '',
    'api_key_validated' => FALSE,
    'api_key_validation_hash' => '',
    'subscription_status' => '',
    'domain_mismatch' => [],
    'topicalboost_api_endpoint' => '',
    'organization_facebook_url' => '',
    'organization_twitter_url' => '',
    'organization_linkedin_url' => '',
    'organization_youtube_url' => '',
    'organization_wikipedia_url' => '',
    'organization_logo_method' => 'auto',
    'organization_logo_fid' => NULL,
    'organization_logo_url' => '',
    'frontend_filter_mode' => 'mentions_behind_toggle',
    'frontend_sort_order' => 'alphabetical',
    'auto_link_topics' => FALSE,
    'skeleton_style' => FALSE,
    'taxonomy_label_singular' => 'Topic',
    'taxonomy_label_plural' => 'Topics',
    'include_excerpt' => FALSE,
    'batch_size' => 35,
    'beta_channel' => FALSE,
    'use_beta_api' => FALSE,
    'error_telemetry_enabled' => TRUE,
    'disable_event_temporal_properties' => FALSE,
    'hide_seo_module_ui' => FALSE,
    'block_until_analyzed' => FALSE,
    'required_permission' => 'administer topicalboost',
    'new_topic_reanalysis_enabled' => FALSE,
    'new_topic_reanalysis_lookback_days' => 30,
    'search_clippings_enabled' => FALSE,
    'citations_widget_enabled' => FALSE,
    'citations_widget_limit' => 20,
    'meta_seo_prompt' => '',
    'meta_social_prompt' => '',
    'meta_title_case_format' => 'title',
    'auto_sync_enabled' => FALSE,
    'search_countries' => ['US'],
    'author_manager_enabled' => FALSE,
    'author_hide_content_types' => [],
    'author_force_show_content_types' => [],
