{#
/**
 * @file
 * TopicalBoost topics display template.
 *
 * Available variables:
 * - node: The node entity.
 * - filtered_topics: Array of filtered TopicalBoost topics with salience data.
 *   Each topic has: term, count, salience_score, salience_category
 * - topics_list_label: Label for the topics section.
 * - maximum_visible_post_topics: Maximum number of topics to show initially.
 * - options: Display options.
 *   - frontend_filter_mode: 'all' | 'mentions_behind_toggle' | 'high_salience_only'
 *
 * Topics are ordered by tier, then alphabetically.
 * Filter mode controls which topics are shown:
 * - "all": show all topics up to max_visible
 * - "mentions_behind_toggle": show about/mainEntity openly, mentions behind Show More
 * - "high_salience_only": only show mainEntity + about tiers
 */
#}

{% set filter_mode = options.frontend_filter_mode|default('mentions_behind_toggle') %}

{% if filtered_topics %}
  {# Separate topics by salience category #}
  {% set about_topics = [] %}
  {% set mentions_topics = [] %}
  {% for topic in filtered_topics %}
    {% if topic.salience_category == 'about' or topic.salience_category == 'mainEntity' %}
      {% set about_topics = about_topics|merge([topic]) %}
    {% else %}
      {% set mentions_topics = mentions_topics|merge([topic]) %}
    {% endif %}
  {% endfor %}

  <div class="topicalboost-section ttd-topics-display">
    <div class="topicalboost-inline-mentions ttd-topics-content">
      <h5 class="mentions-label">{{ topics_list_label }}</h5>
      <div class="mentions-list ttd-topics-links" data-max-visible="{{ maximum_visible_post_topics }}">
        {% if filter_mode == 'all' %}
          {# Show all topics up to max_visible #}
          {% set visible_count = 0 %}
          {% for topic in filtered_topics %}
            {% if visible_count < maximum_visible_post_topics %}
              <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': topic.term.id}) }}" class="mention-tag ttd-main-links">
                {{ topic.term.label|trim }}
              </a>
              {% set visible_count = visible_count + 1 %}
            {% else %}
              <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': topic.term.id}) }}" class="mention-tag ttd-extra-links ttd-topics-display-hidden hidden">
                {{ topic.term.label|trim }}
              </a>
            {% endif %}
          {% endfor %}
          {% if filtered_topics|length > maximum_visible_post_topics %}
            <div class="toggle-mentions-btn ttd-topics-show-extra-button" role="button" tabindex="0">+{{ filtered_topics|length - maximum_visible_post_topics }} more</div>
          {% endif %}

        {% elseif filter_mode == 'mentions_behind_toggle' %}
          {# Show about/mainEntity openly, mentions behind Show More #}
          {% for topic in about_topics %}
            <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': topic.term.id}) }}" class="mention-tag ttd-main-links">
              {{ topic.term.label|trim }}
            </a>
          {% endfor %}
          {% for topic in mentions_topics %}
            <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': topic.term.id}) }}" class="mention-tag ttd-extra-links ttd-topics-display-hidden hidden">
              {{ topic.term.label|trim }}
            </a>
          {% endfor %}
          {% if mentions_topics|length > 0 %}
            <div class="toggle-mentions-btn ttd-topics-show-extra-button" role="button" tabindex="0">+{{ mentions_topics|length }} more</div>
          {% endif %}

        {% elseif filter_mode == 'high_salience_only' %}
          {# Only show mainEntity + about tiers #}
          {% for topic in about_topics %}
            <a href="{{ path('entity.taxonomy_term.canonical', {'taxonomy_term': topic.term.id}) }}" class="mention-tag ttd-main-links">
              {{ topic.term.label|trim }}
            </a>
          {% endfor %}

        {% endif %}
      </div>
    </div>
  </div>
{% endif %}
